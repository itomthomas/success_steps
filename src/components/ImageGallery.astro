---
// src/components/ImageGallery.astro
// Drop-in gallery component — no React, no JS library, pure CSS scroll animation.
// Usage: <ImageGallery /> inside any Astro page/layout.

const images = [
  { src: "/images/imagegallery/new6.webp",      alt: "Gallery Image 1"  },
  { src: "/images/imagegallery/new7.webp",      alt: "Gallery Image 2"  },
  { src: "/images/imagegallery/new8.webp",      alt: "Gallery Image 3"  },
  { src: "/images/imagegallery/new1.webp",      alt: "Gallery Image 4"  },
  { src: "/images/imagegallery/new2.webp",      alt: "Gallery Image 5"  },
  { src: "/images/imagegallery/new3.webp",      alt: "Gallery Image 6"  },
  { src: "/images/imagegallery/new4.webp",      alt: "Gallery Image 7"  },
  { src: "/images/imagegallery/new5.webp",      alt: "Gallery Image 8"  },
  { src: "/images/imagegallery/imggall1.webp",  alt: "Gallery Image 9"  },
  { src: "/images/imagegallery/imggall2.webp",  alt: "Gallery Image 10" },
  { src: "/images/imagegallery/imggall3.webp",  alt: "Gallery Image 11" },
  { src: "/images/imagegallery/imggall4.webp",  alt: "Gallery Image 12" },
  { src: "/images/imagegallery/imggall5.webp",  alt: "Gallery Image 13" },
  { src: "/images/imagegallery/imggall6.webp",  alt: "Gallery Image 14" },
  { src: "/images/imagegallery/imggall7.webp",  alt: "Gallery Image 15" },
  { src: "/images/imagegallery/imggall8.webp",  alt: "Gallery Image 16" },
  { src: "/images/imagegallery/imggall9.webp",  alt: "Gallery Image 17" },
  { src: "/images/imagegallery/imggall10.webp", alt: "Gallery Image 18" },
  { src: "/images/imagegallery/imggall11.webp", alt: "Gallery Image 19" },
  { src: "/images/imagegallery/imggall12.webp", alt: "Gallery Image 20" },
  { src: "/images/imagegallery/imggall13.webp", alt: "Gallery Image 21" },
  { src: "/images/imagegallery/imggall14.webp", alt: "Gallery Image 22" },
  { src: "/images/imagegallery/imggall15.webp", alt: "Gallery Image 23" },
];
---

<section class="gallery-section" aria-label="Image Gallery">
  <div class="gallery-header">
    <h2>Our Gallery</h2>
    <p>Moments from our transformative sessions</p>
  </div>

  <!--
    Performance strategy:
    - Images are duplicated once in HTML for seamless CSS infinite loop (no JS needed)
    - First 4 images use loading="eager" — they appear in the initial viewport
    - All others use loading="lazy" — browser fetches them only when near viewport
    - animation-play-state pauses on hover via CSS only
    - No JavaScript involved in scrolling whatsoever
  -->
  <div class="gallery-track-wrapper">
    <!-- Fade edges -->
    <div class="gallery-fade gallery-fade--left"  aria-hidden="true"></div>
    <div class="gallery-fade gallery-fade--right" aria-hidden="true"></div>

    <div class="gallery-track" aria-hidden="false">
      <!-- Original set -->
      {images.map((img, i) => (
        <div class="gallery-item">
          <img
            src={img.src}
            alt={img.alt}
            width="500"
            height="400"
            loading={i < 4 ? "eager" : "lazy"}
            decoding="async"
          />
        </div>
      ))}
      <!-- Duplicate set for seamless loop — hidden from assistive tech -->
      {images.map((img) => (
        <div class="gallery-item" aria-hidden="true">
          <img
            src={img.src}
            alt=""
            width="500"
            height="400"
            loading="lazy"
            decoding="async"
          />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* ── Section wrapper ────────────────────────────────────── */
  .gallery-section {
    padding: 2rem 0;
    background: #0f0f13;
    overflow: hidden;
  }

  .gallery-header {
    text-align: center;
    margin-bottom: 2.5rem;
    padding: 0 1rem;
  }

  .gallery-header h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: #ffffff;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .gallery-header p {
    color: rgba(255, 255, 255, 0.5);
    font-size: 1rem;
    margin: 0;
  }

  /* ── Track wrapper — clips overflow + holds fade overlays ── */
  .gallery-track-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  /* ── Fade-out edges ─────────────────────────────────────── */
  .gallery-fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 120px;
    z-index: 2;
    pointer-events: none;
  }

  .gallery-fade--left {
    left: 0;
    background: linear-gradient(to right, #0f0f13, transparent);
  }

  .gallery-fade--right {
    right: 0;
    background: linear-gradient(to left, #0f0f13, transparent);
  }

  /* ── Scrolling track ────────────────────────────────────── */
  .gallery-track {
    display: flex;
    gap: 1rem;
    width: max-content;           /* grows to fit all items side by side */

    /*
      The animation translates exactly 50% of the total width (= the original set).
      Because the duplicate set is identical, the loop is visually seamless.
      Duration controls speed: higher = slower. 60s feels natural for 23 images.
    */
    animation: gallery-scroll 60s linear infinite;
    will-change: transform;       /* hint browser to composite on GPU */
  }

  /* Pause on hover — pure CSS, zero JS */
  .gallery-track-wrapper:hover .gallery-track {
    animation-play-state: paused;
  }

  @keyframes gallery-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }  /* slides exactly one full set */
  }

  /* ── Individual image card ──────────────────────────────── */
  .gallery-item {
    flex: 0 0 auto;
    width: 300px;
    height: 220px;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    transition: box-shadow 0.3s ease;
  }

  .gallery-item:hover {
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.6);
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.06);
  }

  /* ── Respect reduced motion preference ──────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .gallery-track {
      animation: none;
      flex-wrap: wrap;
      width: 100%;
      justify-content: center;
      padding: 0 1rem;
    }
    .gallery-fade { display: none; }

    /* Hide duplicate set when not animating */
    .gallery-item[aria-hidden="true"] { display: none; }
  }

  /* ── Responsive card sizing ─────────────────────────────── */
  @media (max-width: 768px) {
    .gallery-item {
      width: 220px;
      height: 165px;
    }
    .gallery-fade { width: 60px; }
  }
</style>