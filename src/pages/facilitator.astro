  </div>
</section>


  <!-- Journey Timeline -->
  <section class="py-5">
    <div class="container">
      <h2 class="text-center display-5 fw-bold mb-5">Professional Journey</h2>
      <div class="timeline-container">
        <div class="timeline-item">
          <div class="timeline-icon bg-primary">
            <i class="bi bi-mortarboard"></i>
          </div>
          <div class="timeline-content">
            <h5>Doctorate - USA</h5>
            <p>Advanced studies in Neurocognitive Psychology</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-icon bg-success">
            <i class="bi bi-trophy"></i>
          </div>
          <div class="timeline-content">
            <h5>NLP Master Certifications</h5>
            <p>ABNLP, AMAP, ICF Coach credentials</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-icon bg-warning">
            <i class="bi bi-mic"></i>
          </div>
          <div class="timeline-content">
            <h5>Motivational Speaker</h5>
            <p>Keynotes on leadership & peak performance</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-icon bg-info">
            <i class="bi bi-book"></i>
          </div>
          <div class="timeline-content">
            <h5>Author & Thought Leader</h5>
            <p>10+ books on psychology & neuroscience</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-5 text-center bg-gradient-primary text-white">
    <div class="container">
      <h2 class="display-5 fw-bold mb-4">Work With India's Leading Psychologist</h2>
      <p class="lead mb-5">Transform lives through SuccessSteps assessments</p>
      <div class="d-flex flex-column flex-lg-row gap-3 justify-content-center">
        <a href="/facilitator" class="btn btn-warning btn-lg px-5 py-3 fw-bold">
          🚀 Become Facilitator
        </a>
        <a href="/contact" class="btn btn-outline-light btn-lg px-5 py-3">
          📞 Schedule Call
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hover-lift:hover {
    transform: translateY(-10px);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  .hover-cert:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.15) !important;
  }
  .animate-fade-in {
    animation: fadeInUp 1s ease-out;
  }
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
  
  .timeline-container {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
  }
  .timeline-container::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, #667eea, #764ba2);
    transform: translateX(-50%);
  }
  .timeline-item {
    position: relative;
    margin: 4rem 0;
    display: flex;
    align-items: center;
  }
  .timeline-item:nth-child(even) {
    flex-direction: row-reverse;
  }
  .timeline-icon {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 1.5rem;
    z-index: 1;
    flex-shrink: 0;
  }
  .timeline-content {
    background: white;
    padding: 2rem;
    border-radius: 12px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.1);
    max-width: 45%;
    margin: 0 2rem;
  }
  .timeline-item:nth-child(even) .timeline-content {
    margin-left: 0;
  }
  
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-15px); }
  }
</style>
