---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import antony from '../images/antony.png';
---

<BaseLayout title="Dr. Antony Augusthy | SuccessSteps Founder">
  <!-- Hero Section -->
  <section class="bg-gradient-primary text-white py-5 mb-5 position-relative overflow-hidden" 
           style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-4 text-center text-lg-start">
        <div class="founder-hero-img animate-float mb-4 mb-lg-0">
            <Image 
                src={antony}
                alt="Dr. Antony Augusthy"
                class="img-fluid rounded-4 shadow-lg border border-4 border-white"
                style="width: 280px; height: 380px; object-fit: cover;"
                width={280}
                height={380}
            />
            </div>
          <!-- <div class="founder-hero-img animate-float mb-4 mb-lg-0">
            <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=300&h=400&fit=crop&crop=face" 
                 alt="Dr. Antony Augusthy" 
                 class="img-fluid rounded-4 shadow-lg border border-4 border-white"
                 style="width: 280px; height: 380px; object-fit: cover;">
          </div> --!>
        </div>
        <div class="col-lg-8">
          <h1 class="display-3 fw-bold mb-4 animate-fade-in">
            Dr. <span class="text-warning">Antony Augusthy</span>
          </h1>
          <h2 class="display-6 fw-normal mb-4 opacity-90">Neurocognitive Psychologist</h2>
          <p class="lead mb-5">Founder of SuccessSteps | 25+ International Certifications | Author | Transformational Leader</p>
          <div class="d-flex gap-3 flex-wrap">
            <a href="#expertise" class="btn btn-warning btn-lg px-5 py-3 fw-bold">
              Explore Expertise
            </a>
            <a href="/contact" class="btn btn-outline-light btn-lg px-5 py-3">
              Book Consultation
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="py-4 bg-dark text-white">
    <div class="container">
      <div class="row text-center">
        <div class="col-md-3">
          <div class="h2 mb-1">25+</div>
          <div>International Certifications</div>
        </div>
        <div class="col-md-3">
          <div class="h2 mb-1">10+</div>
          <div>Books Authored</div>
        </div>
        <div class="col-md-3">
          <div class="h2 mb-1">500+</div>
          <div>Professionals Trained</div>
        </div>
        <div class="col-md-3">
          <div class="h2 mb-1">15+</div>
          <div>Years Experience</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Expertise -->
  <section id="expertise" class="py-5">
    <div class="container">
      <h2 class="text-center display-5 fw-bold mb-5 pb-4">Core Expertise Areas</h2>
      <div class="row g-4">
        <div class="col-lg-4 col-md-6">
          <div class="card border-0 shadow-lg h-100 hover-lift">
            <div class="card-body text-center p-5">
              <div class="bg-primary rounded-circle mx-auto mb-4 p-4 d-inline-block" style="width: 90px; height: 90px;">
                <i class="bi bi-brain text-white fs-3"></i>
              </div>
              <h4 class="fw-bold mb-3">Neurocognitive Psychology</h4>
              <p class="text-muted lead mb-0">Deep expertise in cognition, perception, and brain processes</p>
            </div>
          </div>
        </div>
        <div class="col-lg-4 col-md-6">
          <div class="card border-0 shadow-lg h-100 hover-lift">
            <div class="card-body text-center p-5">
              <div class="bg-warning rounded-circle mx-auto mb-4 p-4 d-inline-block" style="width: 90px; height: 90px;">
                <i class="bi bi-chat-dots text-dark fs-3"></i>
              </div>
              <h4 class="fw-bold mb-3">NLP Master Practitioner Trainer</h4>
              <p class="text-muted lead mb-0">Certified by American Board of NLP (USA) & AMAP</p>
            </div>
          </div>
        </div>
        <div class="col-lg-4 col-md-6">
          <div class="card border-0 shadow-lg h-100 hover-lift">
            <div class="card-body text-center p-5">
              <div class="bg-success rounded-circle mx-auto mb-4 p-4 d-inline-block" style="width: 90px; height: 90px;">
                <i class="bi bi-fire text-white fs-3"></i>
              </div>
              <h4 class="fw-bold mb-3">Peak Performance Coach</h4>
              <p class="text-muted lead mb-0">Executive Leadership & Emotional Intelligence Specialist</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Certifications Grid - ALL 21 CERTIFICATIONS -->
<section class="py-5 bg-light">
  <div class="container">
    <div class="text-center mb-5">
      <h2 class="display-5 fw-bold mb-4">21 World-Class Certifications</h2>
      <p class="lead text-muted mb-0">Internationally recognized credentials from USA, UK, Belgium & India</p>
    </div>
    
    <div class="row g-3 g-lg-2">
      <!-- NLP Certifications -->
      <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="cert-badge p-3 rounded-3 bg-white shadow-sm border hover-cert">
          <div class="fw-bold text-primary mb-1 small">NLP Master Practitioner & Coach</div>
          <small class="text-muted">ABNLP-USA</small>
        </div>
      </div>
      
      <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="cert-badge p-3 rounded-3 bg-white shadow-sm border hover-cert">
          <div class="fw-bold text-primary mb-1 small">NLP Master Practitioner Expert</div>
          <small class="text-muted">AMAP-USA</small>
        </div>
      </div>
      
      <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="cert-badge p-3 rounded-3 bg-white shadow-sm border hover-cert">
          <div class="fw-bold text-primary mb-1 small">Train The Trainer Advanced</div>
          <small class="text-muted">Media Training Worldwide-USA</small>
        </div>
      </div>
      
      <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="cert-badge p-3 rounded-3 bg-white shadow-sm border hover-cert">
          <div class="fw-bold text-primary mb-1 small">NLP Practitioner</div>
          <small class="text-muted">ABNLP, IAPCCT, NLPCA</small>
        </div>
      </div>
      
      <!-- Coaching Certifications -->
      <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="cert-badge p-3 rounded-3 bg-white shadow-sm border hover-cert">
          <div class="fw-bold text-success mb-1 small">NLP Coach</div>
          <small class="text-muted">NLPCA, IAPCCT</small>
        </div>
      </div>
      
      <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="cert-badge p-3 rounded-3 bg-white shadow-sm border hover-cert">
          <div class="fw-bold text-success mb-1 small">Advanced NLP Coaching Diploma</div>
          <small class="text-muted">ICF-CCE, IAPCCT, NLPCA</small>
        </div>
      </div>
      
      <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="cert-badge p-3 rounded-3 bg-white shadow-sm border hover-cert">
          <div class="fw-bold text-success mb-1 small">Wellness Coach</div>
          <small class="text-muted">ICF-CCE, IAPCCT, NLPCA</small>
        </div>
      </div>
      
      <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="cert-badge p-3 rounded-3 bg-white shadow-sm border hover-cert">
          <div class="fw-bold text-success mb-1 small">Professional Executive Coach</div>
          <small class="text-muted">ICF International</small>
        </div>
      </div>
      
      <!-- Performance & Learning -->
      <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="cert-badge p-3 rounded-3 bg-white shadow-sm border hover-cert">
          <div class="fw-bold text-warning mb-1 small">Accelerated Learning Coach</div>
          <small class="text-muted">IAPCCT, NLPCA</small>
        </div>
      </div>
      
      <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="cert-badge p-3 rounded-3 bg-white shadow-sm border hover-cert">
          <div class="fw-bold text-warning mb-1 small">Group Peak Performance Coach</div>
          <small class="text-muted">IAPCCT, NLPCA</small>
        </div>
      </div>
      
      <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="cert-badge p-3 rounded-3 bg-white shadow-sm border hover-cert">
          <div class="fw-bold text-warning mb-1 small">Proactive Coaching</div>
          <small class="text-muted">IAPCCT, NLPCA</small>
        </div>
      </div>
      
      <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="cert-badge p-3 rounded-3 bg-white shadow-sm border hover-cert">
          <div class="fw-bold text-warning mb-1 small">Associate Executive Coach</div>
          <small class="text-muted">ICF-USA</small>
        </div>
      </div>
      
      <!-- Therapy & Hypnosis -->
      <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="cert-badge p-3 rounded-3 bg-white shadow-sm border hover-cert">
          <div class="fw-bold text-info mb-1 small">Ericksonian Hypnosis Master</div>
          <small class="text-muted">IAPCCT, NLPCA</small>
        </div>
      </div>
      
      <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="cert-badge p-3 rounded-3 bg-white shadow-sm border hover-cert">
          <div class="fw-bold text-info mb-1 small">Emotional Intelligence Coach</div>
          <small class="text-muted">ICF-CCE USA</small>
        </div>
      </div>
      
      <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="cert-badge p-3 rounded-3 bg-white shadow-sm border hover-cert">
          <div class="fw-bold text-info mb-1 small">Cognitive Behaviour Therapy</div>
          <small class="text-muted">IAOTH-UK</small>
        </div>
      </div>
      
      <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="cert-badge p-3 rounded-3 bg-white shadow-sm border hover-cert">
          <div class="fw-bold text-info mb-1 small">Gestalt Psychotherapy</div>
          <small class="text-muted">REBT-IAOTH-UK</small>
        </div>
      </div>
      
      <!-- Academic & Specialized -->
      <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="cert-badge p-3 rounded-3 bg-white shadow-sm border hover-cert">
          <div class="fw-bold text-secondary mb-1 small">Rational Emotive Behaviour Therapy</div>
          <small class="text-muted">REBT-IAOTH-UK</small>
        </div>
      </div>
      
      <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="cert-badge p-3 rounded-3 bg-white shadow-sm border hover-cert">
          <div class="fw-bold text-secondary mb-1 small">Diploma Modern Applied Psychology</div>
          <small class="text-muted">Academy-USA</small>
        </div>
      </div>
      
      <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="cert-badge p-3 rounded-3 bg-white shadow-sm border hover-cert">
          <div class="fw-bold text-secondary mb-1 small">PG Diploma Instructional Design</div>
          <small class="text-muted">PGDID Symbiosis Pune</small>
        </div>
      </div>
      
      <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="cert-badge p-3 rounded-3 bg-white shadow-sm border hover-cert">
          <div class="fw-bold text-secondary mb-1 small">Neuroscience for Personal Dev.</div>
          <small class="text-muted">Brain Academy, Belgium</small>
        </div>
      </div>
    </div>
    
    <!-- Certification Legend -->
    <div class="text-center mt-5 pt-4">
      <div class="row justify-content-center">
        <div class="col-md-8">
          <div class="alert alert-info border-0 shadow-sm">
            <h6 class="mb-2"><i class="bi bi-award text-primary me-2"></i>Legend:</h6>
            <div class="row text-start">
              <div class="col-sm-6 col-md-4 mb-2">
                <span class="badge bg-primary me-1">USA</span> American certifications
              </div>
              <div class="col-sm-6 col-md-4 mb-2">
                <span class="badge bg-info me-1">UK</span> United Kingdom credentials
              </div>
              <div class="col-sm-6 col-md-4 mb-2">
                <span class="badge bg-success me-1">ICF</span> International Coach Federation
              </div>
            </div>
          </div>
