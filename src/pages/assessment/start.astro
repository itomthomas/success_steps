---
export const prerender = false;
import BaseLayout from "../../layouts/BaseLayout.astro";
const token = Astro.url.searchParams.get("token");

if (!token) {
  return Astro.redirect("/assessment/error?reason=missing");
}
---
<BaseLayout>
  <!-- Page-specific HEAD -->
  <Fragment slot="head">
    <title>Starting Assessment | Success Steps</title>
  </Fragment>

  <div class="d-flex align-items-center justify-content-center min-vh-100">
    <div class="card shadow-sm border-0 p-4 text-center" style="max-width:420px;">
      <div class="spinner-border text-primary mb-3" role="status"></div>

      <h5 class="fw-semibold mb-2">Preparing Your Assessment</h5>
      <p class="text-muted mb-0">
        Verifying access and setting things up…
      </p>
    </div>
  </div>

  <script is:inline>
    (async () => {
      const token = new URLSearchParams(window.location.search).get("token");
      if (!token) {
        window.location.replace("/assessment/error?reason=missing");
        return;
      }

      try {
        const res = await fetch("/api/validate-token", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ token })
        });

        const data = await res.json();

        if (!res.ok || !data.success) {
          window.location.replace(
            `/assessment/error?reason=${data.reason || "invalid"}`
          );
          return;
        }

        sessionStorage.setItem("assessmentSession", "active");
        sessionStorage.setItem("assessmentToken", token);
        sessionStorage.setItem("assessmentStartedAt", Date.now().toString());

        window.location.replace("/assessment");
      } catch {
        window.location.replace("/assessment/error?reason=server");
      }
    })();
  </script>
</BaseLayout>
