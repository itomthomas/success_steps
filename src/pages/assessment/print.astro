---
// src/pages/print.astro
// Permanent, shareable, configurable report page.
// Access: /print?rt=rt_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
//
// Per-test display is driven by the "Test_Display_Config" sheet in GAS:
//   Image_URL      → test header image (path in /public or full https URL)
//   Chart_Type     → bar_vertical | radar | auto  (bar_horizontal removed)
//   Theme_Color    → hex colour for the test band and chart
//   Subtest_Layout → side_image | cards | full_width
//   Section_Color  → light background tint for the test band

export const prerender = false;

import { Image } from 'astro:assets';
import pdfMain from '../../images/pdf_Front1.jpg';
import LOGO    from '../../images/fitLogo.png';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Assessment Report | Success Steps</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/print-report.css" />
</head>

<body>

  <!-- Screen toolbar (hidden on print via CSS) -->
  <div class="screen-toolbar">
    <a href="/" class="btn-back">← Home</a>
    <h1>Success Steps — Assessment Report</h1>
    <button class="btn-print" onclick="window.print()">🖨️ Save as PDF / Print</button>
  </div>

  <div class="print-shell">
    <div class="report-paper">

      <div id="loadingState">
        <div class="spinner"></div>
        <p>Loading your report…</p>
      </div>
      <div id="errorState"></div>

      <!-- Astro-resolved image paths exposed to client JS via data attributes -->
      <span id="__logoSrc"     data-src={LOGO.src}    style="display:none"></span>
      <span id="__coverImgSrc" data-src={pdfMain.src}  style="display:none"></span>

      <!-- All pages injected here by JS -->
      <div id="reportRoot" style="display:none;"></div>

    </div>
  </div>


  <script is:inline>
  /* ═══════════════════════════════════════════════════════════════
     PALETTE — fallback colours when no theme is configured
  ═══════════════════════════════════════════════════════════════ */
  var DEFAULT_COLOURS = [
    "#0d6efd","#0dcaf0","#20c997","#ffc107",
    "#fd7e14","#6f42c1","#d63384","#198754","#dc3545","#6c757d"
  ];

  /* ═══════════════════════════════════════════════════════════════
     REPORT TOKEN
  ═══════════════════════════════════════════════════════════════ */
  var params      = new URLSearchParams(window.location.search);
  var reportToken = params.get("rt");

  if (!reportToken || !reportToken.startsWith("rt_")) {
    document.getElementById("loadingState").style.display = "none";
    var errEl = document.getElementById("errorState");
    errEl.style.display = "block";
    errEl.innerHTML =
      "<p style='text-align:center;padding:60px 20px;color:#6c757d;'>" +
        "<strong style='display:block;font-size:1.1rem;margin-bottom:8px;color:#1a1a2e;'>Invalid Report Link</strong>" +
        "This link is missing or incorrect. Please use the link provided on your " +
        "assessment completion page, or contact " +
        "<a href='mailto:successtepsnlpa@gmail.com'>successtepsnlpa@gmail.com</a>." +
      "</p>";
  }

  /* ═══════════════════════════════════════════════════════════════
     IMAGE SRCS
  ═══════════════════════════════════════════════════════════════ */
  var LOGO_SRC      = document.getElementById("__logoSrc").dataset.src;
  var COVER_IMG_SRC = document.getElementById("__coverImgSrc").dataset.src;

  /* ═══════════════════════════════════════════════════════════════
     DATE
  ═══════════════════════════════════════════════════════════════ */
  var now      = new Date();
  var genLabel = "Generated " + now.toLocaleDateString("en-GB", {
    day: "numeric", month: "long", year: "numeric"
  });

  /* ═══════════════════════════════════════════════════════════════
     SHARED: PAGE HEADER
  ═══════════════════════════════════════════════════════════════ */
  function pageHeaderHTML(name) {
    return '<div class="page-header">' +
      '<div class="header-brand">' +
        '<img src="' + LOGO_SRC + '" alt="Success Steps" height="32" />' +
        '<span class="header-site">www.successsteps.in</span>' +
      '</div>' +
      '<div class="header-right">' +
        '<span class="header-report-type">Psychometric Assessment</span>' +
        '<span class="header-name">' + (name || "—") + '</span>' +
        '<span class="header-date">' + genLabel + '</span>' +
      '</div>' +
    '</div>';
  }

  /* ═══════════════════════════════════════════════════════════════
     SHARED: PAGE FOOTER
  ═══════════════════════════════════════════════════════════════ */
  var PAGE_FOOTER_HTML =
    '<div class="page-footer">' +
      '<span class="footer-left">Dr. Antony Augusthy · Neurocognitive Psychologist</span>' +
      '<span class="footer-center">Success Steps NLP Academy · successtepsnlpa@gmail.com</span>' +
      '<span class="footer-confidential">Confidential</span>' +
    '</div>';

  /* ═══════════════════════════════════════════════════════════════
     HELPER: lighten a hex colour for the section background
  ═══════════════════════════════════════════════════════════════ */
  function hexToRgba(hex, alpha) {
    var r = parseInt(hex.slice(1,3), 16);
    var g = parseInt(hex.slice(3,5), 16);
    var b = parseInt(hex.slice(5,7), 16);
    return "rgba(" + r + "," + g + "," + b + "," + alpha + ")";
  }



  /* ═══════════════════════════════════════════════════════════════
     PAGE 1 — COVER
  ═══════════════════════════════════════════════════════════════ */
  function buildCoverPage(profile) {
    var name     = profile.name      || "—";
    var email    = profile.email     || "—";
    var gender   = profile.gender    || "—";
    var age      = profile.age       || "—";
    var testedOn = profile.createdAt
      ? new Date(profile.createdAt).toLocaleDateString("en-GB", {
          day: "numeric", month: "long", year: "numeric" })
      : "—";

    var sec = document.createElement("section");
    sec.className = "page cover";
    sec.innerHTML =
      '<div class="cover-topbar">' +
        '<div class="cover-topbar-brand">' +
          '<img src="' + LOGO_SRC + '" alt="Success Steps NLP Academy" height="42" />' +
          '<span class="cover-topbar-url">www.successsteps.in</span>' +
        '</div>' +
        '<span class="cover-topbar-confidential">Confidential</span>' +
      '</div>' +

      '<div class="cover-title-band">' +
        '<div class="cover-report-label">Psychometric Assessment Report</div>' +
        '<h1>Understanding Your<br/><em>Mind &amp; Potential</em></h1>' +
      '</div>' +

      '<div class="cover-image-wrap">' +
        '<img src="' + COVER_IMG_SRC + '" alt="Assessment Report Cover" />' +
      '</div>' +

      '<div class="cover-meta-strip">' +
        '<div class="cover-meta-item"><div class="cover-meta-label">Name</div><div class="cover-meta-value">' + name + '</div></div>' +
        '<div class="cover-meta-item"><div class="cover-meta-label">Gender / Age</div><div class="cover-meta-value">' + gender + ' / ' + age + '</div></div>' +
        '<div class="cover-meta-item"><div class="cover-meta-label">Email</div><div class="cover-meta-value">' + email + '</div></div>' +
        '<div class="cover-meta-item"><div class="cover-meta-label">Tested On</div><div class="cover-meta-value">' + testedOn + '</div></div>' +
      '</div>' +

      '<div class="cover-taxonomy">' +
        '<h2>Neuro-Cognitive · Emotional Intelligence<br/>Behaviour Competency Mapping</h2>' +
      '</div>' +

      '<div class="cover-analyst">' +
        '<div class="cover-analyst-avatar">🧠</div>' +
        '<div class="cover-analyst-info">' +
          '<div class="cover-analyst-by">Test Analysis &amp; Brain Mapping by</div>' +
          '<div class="cover-analyst-name">Dr. Antony Augusthy</div>' +
          '<div class="cover-analyst-title">Neurocognitive Psychologist · NLP Master Practitioner Trainer</div>' +
        '</div>' +
      '</div>' +

      '<div class="cover-credentials">' +
        '<span class="cover-cred-pill">ABNLP · USA</span>' +
        '<span class="cover-cred-pill">ICF Executive Coach</span>' +
        '<span class="cover-cred-pill">IAOTH · UK</span>' +
        '<span class="cover-cred-pill">25+ International Certifications</span>' +
      '</div>' +

      '<div class="cover-bottombar">' +
        '<span>Success Steps NLP Academy, Thane, Mumbai</span>' +
        '<span>' + genLabel + '</span>' +
      '</div>';

    return sec;
  }

  /* ═══════════════════════════════════════════════════════════════
     PAGE 2 — SUMMARY + GUIDANCE NOTE
  ═══════════════════════════════════════════════════════════════ */
  function buildSummaryPage(tests, name) {
    var tableRows = tests.map(function(test, i) {
      var subtests    = test.subtests || [];
      var maxPossible = subtests.reduce(function(s, st){ return s + (Number(st.max_score) || 0); }, 0);
      var totalScore  = subtests.reduce(function(s, st){ return s + (Number(st.raw_score) || 0); }, 0);
      var pct         = maxPossible > 0 ? Math.round((totalScore / maxPossible) * 100) : 0;
      var themeColor  = (test.display && test.display.themeColor) || "#0d6efd";
      return '<tr>' +
        '<td><span class="summary-sn" style="background:' + themeColor + '">' + (i + 1) + '</span></td>' +
        '<td style="font-weight:600;">' + test.test_name + '</td>' +
        '<td>' + subtests.length + ' subtest' + (subtests.length !== 1 ? 's' : '') + '</td>' +
        '<td><span class="summary-score-badge" style="background:' + hexToRgba(themeColor, 0.1) + ';color:' + themeColor + '">' +
          totalScore + ' / ' + maxPossible + ' &nbsp;·&nbsp; ' + pct + '%' +
        '</span></td>' +
      '</tr>';
    }).join("");

    var sec = document.createElement("section");
    sec.className = "page";
    sec.innerHTML = pageHeaderHTML(name);

    var body = document.createElement("div");
    body.className = "page-body";
    body.innerHTML =
      '<h2 class="section-title">Assessment Overview</h2>' +
      '<p class="summary-intro">The following assessments were conducted as part of your personalised psychometric evaluation. Each test is detailed in the pages that follow, with subtest breakdowns, scores, and individual feedback.</p>' +
      '<table class="summary-table">' +
        '<thead><tr><th style="width:44px;">#</th><th>Assessment</th><th>Subtests</th><th>Score</th></tr></thead>' +
        '<tbody>' + tableRows + '</tbody>' +
      '</table>' +
      '<div class="guidance-card">' +
        '<div class="guidance-header">' +
          '<div class="guidance-icon">💙</div>' +
          '<div class="guidance-title"><span>A note for</span>Students · Parents · Teachers</div>' +
        '</div>' +
        '<div class="guidance-body">' +
          '<p>We warmly encourage parents and teachers to carefully read and reflect on this report before initiating any conversation with their child or student. This assessment is not a measure of worth — it is a map of <strong>inner strengths, hidden talents, and areas of growth</strong> waiting to be nurtured.</p>' +
          '<p>Please use the insights shared here to build a <strong>supportive, stress-free environment</strong> — one where your child feels safe to explore, question, and discover who they truly are. Avoid comparing scores or outcomes with others; every profile is unique and equally valuable.</p>' +
          '<p>If questions arise, our team is available to walk you through the findings in a one-to-one counselling session so the report translates into meaningful, positive action for your child.</p>' +
        '</div>' +
        '<div class="guidance-sign">' +
          '<div><div class="guidance-sign-name">Dr. Antony Augusthy</div><div class="guidance-sign-title">Neurocognitive Psychologist · Success Steps NLP Academy</div></div>' +
          '<div class="guidance-wishes">🌟 Wishing you and your child every success!</div>' +
        '</div>' +
      '</div>';

    sec.appendChild(body);
    sec.insertAdjacentHTML("beforeend", PAGE_FOOTER_HTML);
    return sec;
  }

  /* ═══════════════════════════════════════════════════════════════
     SUBTEST RENDERERS — three layout modes
  ═══════════════════════════════════════════════════════════════ */

  /* cards — original grid layout (default) */
  function renderSubtestsCards(subtests, themeColor) {
    var grid = document.createElement("div");
    grid.className = "subtests-grid";
    subtests.forEach(function(st, si) {
      var colour = themeColor || DEFAULT_COLOURS[si % DEFAULT_COLOURS.length];
      var maxS   = Number(st.max_score) || 1;
      var rawS   = Number(st.raw_score) || 0;
      var pct    = Math.min(100, Math.round((rawS / maxS) * 100));

      var card = document.createElement("div");
      card.className = "subtest-card";
      card.style.borderLeftColor = colour;
      card.innerHTML =
        '<div class="subtest-card-header">' +
          '<h4>' + st.subtest_name + '</h4>' +
          '<span class="level-pill" style="background:' + colour + '">' + (st.level_label || "—") + '</span>' +
        '</div>' +
        '<div class="subtest-score">' +
          'Score: <strong>' + st.raw_score + '</strong>' +
          '<span style="color:#adb5bd"> / ' + st.max_score + '</span>' +
          '&nbsp;<span style="color:#adb5bd">(' + st.score_range + ')</span>' +
        '</div>' +
        '<div class="score-mini-bar-wrap"><div class="score-mini-bar" style="width:' + pct + '%;background:' + colour + '"></div></div>' +
        '<div class="subtest-feedback">' + (st.feedback || "—") + '</div>';
      grid.appendChild(card);
    });
    return grid;
  }

  /* ─────────────────────────────────────────────────────────────
     HELPER: parse feedback string into <li> bullet items.
     GAS feedback uses "• " as separator between points.
  ───────────────────────────────────────────────────────────── */
  function feedbackToBullets(feedbackRaw) {
    if (!feedbackRaw) return "<li>—</li>";
    var parts = feedbackRaw
      .split("•")
      .map(function(s){ return s.trim(); })
      .filter(function(s){ return s.length > 0; });
    if (parts.length === 0) return "<li>" + feedbackRaw + "</li>";
    return parts.map(function(p){ return "<li>" + p + "</li>"; }).join("");
  }

  /* side_image layout
     ┌─────────────────────────────────────────────────────┐
     │  Subtest name                       [Level pill]    │  full-width header
     │  Score: X / Y  (range)  [mini bar]                 │  full-width score row
     ├─────────────────────┬───────────────────────────────┤
     │                     │  Feedback                     │
     │     IMAGE  50%      │  • Bullet one          50%    │
     │                     │  • Bullet two                 │
     └─────────────────────┴───────────────────────────────┘
     One card per row — no grid wrapping.
  */
  function renderSubtestsSideImage(subtests, themeColor, subtestImageUrls, imageSizePct) {
    var wrap = document.createElement("div");
    wrap.className = "si-cards-wrap";

    subtests.forEach(function(st, si) {
      var colour = themeColor || DEFAULT_COLOURS[si % DEFAULT_COLOURS.length];
      var maxS   = Number(st.max_score) || 1;
      var rawS   = Number(st.raw_score) || 0;
      var pct    = Math.min(100, Math.round((rawS / maxS) * 100));

      // Per-subtest image URL — falls back to blank if not set
      var stImgUrl = (subtestImageUrls[si] || "").trim();
      
      // FIX 1: Removed inline 'width' percentage from the img tag itself. 
      // It should just fill 100% of its available container space.
     // var imgWidthStyle = 'width:100%;height:100%;object-fit:cover;display:block;';
      var thumbHTML = stImgUrl
        ? '<img src="' + stImgUrl + '" alt="' + st.subtest_name + '" style="' + '" />'
        : '';   // blank → triggers cards fallback below

      var bulletItems = feedbackToBullets(st.feedback);

      // If no image URL for this subtest → render as a standard card (cards fallback)
      if (!stImgUrl) {
        var fallbackCard = document.createElement("div");
        fallbackCard.className = "subtest-card";
        fallbackCard.style.borderLeftColor = colour;
        fallbackCard.innerHTML =
          '<div class="subtest-card-header">' +
            '<h4>' + st.subtest_name + '</h4>' +
            '<span class="level-pill" style="background:' + colour + '">' + (st.level_label || "—") + '</span>' +
          '</div>' +
          '<div class="subtest-score">' +
            'Score: <strong>' + st.raw_score + '</strong>' +
            '<span style="color:#adb5bd"> / ' + st.max_score + '</span>' +
            '&nbsp;<span style="color:#adb5bd">(' + (st.score_range || "") + ')</span>' +
          '</div>' +
          '<div class="score-mini-bar-wrap"><div class="score-mini-bar" style="width:' + pct + '%;background:' + colour + '"></div></div>' +
          '<div class="subtest-feedback">' + (st.feedback || "—") + '</div>';
        wrap.appendChild(fallbackCard);
        return;   // skip si-card for this subtest
      }

      // Has image → full si-card with image | bullets
      // image-half width is controlled by imageSizePct from sheet
      var feedbackPct = (100 - imageSizePct) + "%";
      var card = document.createElement("div");
      card.className = "si-card";
      card.style.borderLeftColor = colour;
      card.style.borderTopColor  = colour;

      card.innerHTML =
        /* ── Top: name + score, full width ── */
        '<div class="si-card-top">' +
          '<div class="si-card-header">' +
            '<h4 class="si-subtest-name">' + st.subtest_name + '</h4>' +
            '<span class="level-pill" style="background:' + colour + '">' + (st.level_label || "—") + '</span>' +
          '</div>' +
          '<div class="si-score-row">' +
            '<span class="si-score-text">' +
              'Score:&nbsp;<strong>' + st.raw_score + '</strong>' +
              '<span style="color:#adb5bd">&nbsp;/&nbsp;' + st.max_score + '</span>' +
              '&nbsp;<span style="color:#adb5bd">(' + (st.score_range || "") + ')</span>' +
            '</span>' +
            '<div class="score-mini-bar-wrap si-bar"><div class="score-mini-bar" style="width:' + pct + '%;background:' + colour + '"></div></div>' +
          '</div>' +
        '</div>' +
        /* ── Bottom: image | bullets, widths set by imageSizePct ── */
        '<div class="si-card-body" style="grid-template-columns:' + imageSizePct + '% ' + feedbackPct + '">' +
          '<div class="si-image-half">' + 
             '<div class="si-image-container">' + thumbHTML + '</div>' + 
          '</div>' +
          '<div class="si-feedback-half">' +
            '<div class="si-feedback-label" style="color:' + colour + '">Feedback</div>' +
            '<ul class="si-bullet-list">' + bulletItems + '</ul>' +
          '</div>' +
        '</div>';

      wrap.appendChild(card);
    });
    return wrap;
  }

  /* full_width — one subtest per full-width row, richer layout */
  function renderSubtestsFullWidth(subtests, themeColor) {
    var wrap = document.createElement("div");
    subtests.forEach(function(st, si) {
      var colour = themeColor || DEFAULT_COLOURS[si % DEFAULT_COLOURS.length];
      var maxS   = Number(st.max_score) || 1;
      var rawS   = Number(st.raw_score) || 0;
      var pct    = Math.min(100, Math.round((rawS / maxS) * 100));

      var row = document.createElement("div");
      row.className = "subtest-full-width";
      row.style.borderLeftColor = colour;
      row.innerHTML =
        '<div class="subtest-fw-header">' +
          '<h4 class="subtest-name-text">' + st.subtest_name + '</h4>' +
          '<span class="level-pill" style="background:' + colour + '">' + (st.level_label || "—") + '</span>' +
        '</div>' +
        '<div class="subtest-fw-score">' +
          'Score: <strong>' + st.raw_score + '</strong>' +
          '<span style="color:#adb5bd"> / ' + st.max_score + '</span>' +
          '&nbsp;<span style="color:#adb5bd">(' + st.score_range + ')</span>' +
        '</div>' +
        '<div class="score-mini-bar-wrap"><div class="score-mini-bar" style="width:' + pct + '%;background:' + colour + '"></div></div>' +
        '<div class="subtest-fw-feedback">' + (st.feedback || "—") + '</div>';
      wrap.appendChild(row);
    });
    return wrap;
  }

  /* ═══════════════════════════════════════════════════════════════
     HELPER — resolve chart type (bar_vertical | radar only)
     "auto" → radar if ≥4 subtests, bar_vertical otherwise
     bar_horizontal is removed; any old value maps to bar_vertical.
  ═══════════════════════════════════════════════════════════════ */
  function resolveChartType(display, subtestCount) {
    var ct = (display && display.chartType) || "bar_vertical";
    if (ct === "auto")          return subtestCount >= 4 ? "radar" : "bar_vertical";
    if (ct === "bar_horizontal") return "bar_vertical";   // removed — always vertical
    return ct;   // "bar_vertical" | "radar"
  }

  /* ═══════════════════════════════════════════════════════════════
     PAGE 3…N — ONE PAGE PER TEST
     Rules:
       a. No test-image-panel — chart is always full-width below band
       b. Single chart, type from sheet, default bar_vertical
       c. bar_vertical only — fixed medium bar width
       d. ≤2 subtests → no chart row at all
       e. Per-subtest imageUrl from display.subtestImageUrls[]
          blank url for a subtest → falls back to cards style for that card
       f. Image size % from display.imageSizePct (default 45)
  ═══════════════════════════════════════════════════════════════ */
  function buildTestPage(test, ti, name) {
    var subtests         = test.subtests || [];
    var display          = test.display  || {};
    var themeColor       = display.themeColor       || "#0d6efd";
    var sectionColor     = display.sectionColor     || "#f0f7ff";
    var subtestLayout    = display.subtestLayout    || "cards";
    var chartType        = resolveChartType(display, subtests.length);
    var imageSizePct     = Number(display.imageSizePct) || 45;
    // Per-subtest image URLs: array aligned to subtests array
    var subtestImageUrls = display.subtestImageUrls || [];

    var maxPossible = subtests.reduce(function(s, st){ return s + (Number(st.max_score) || 0); }, 0);
    var totalScore  = subtests.reduce(function(s, st){ return s + (Number(st.raw_score) || 0); }, 0);
    var showChart   = subtests.length > 2;   // rule d: skip chart for ≤2 subtests

    var sec = document.createElement("section");
    sec.className = "page";
    sec.innerHTML = pageHeaderHTML(name);

    var body = document.createElement("div");
    body.className = "page-body";

    /* ── a. Test header band ── */
    var bandDiv = document.createElement("div");
    bandDiv.innerHTML =
      '<div class="test-header-band">' +
        '<div class="test-header-band-color" style="background:' + themeColor + '"></div>' +
        '<div class="test-header-band-content" style="background:' + sectionColor + '">' +
          '<div class="test-header-band-title" style="color:' + themeColor + '">' + test.test_name + '</div>' +
          '<span class="total-badge" style="background:' + themeColor + '">' +
            'Total: ' + totalScore + ' / ' + maxPossible +
          '</span>' +
        '</div>' +
      '</div>';
    body.appendChild(bandDiv);

    /* ── b/c/d. Chart — full-width, single, only when >2 subtests ── */
    if (showChart) {
      var chartDiv = document.createElement("div");
      chartDiv.className = "chart-panel-full";
      chartDiv.innerHTML =
        '<h6>' + (chartType === "radar" ? "Profile Overview" : "Subtest Scores") + '</h6>' +
        '<div class="chart-wrap-vertical">' +
          '<canvas id="chart_' + ti + '"></canvas>' +
        '</div>';
      body.appendChild(chartDiv);
    }

    /* ── e/f. Subtest cards ── */
    var subtestSection = document.createElement("div");
    if (subtestLayout === "side_image") {
      subtestSection.appendChild(
        renderSubtestsSideImage(subtests, themeColor, subtestImageUrls, imageSizePct)
      );
    } else if (subtestLayout === "full_width") {
      subtestSection.appendChild(renderSubtestsFullWidth(subtests, themeColor));
    } else {
      subtestSection.appendChild(renderSubtestsCards(subtests, themeColor));
    }
    body.appendChild(subtestSection);

    sec.appendChild(body);
    sec.insertAdjacentHTML("beforeend", PAGE_FOOTER_HTML);
    return sec;
  }

  /* ═══════════════════════════════════════════════════════════════
     CHART DRAWING — single chart per test, bar_vertical or radar
  ═══════════════════════════════════════════════════════════════ */
  function drawCharts(test, ti) {
    var subtests   = test.subtests || [];
    if (subtests.length <= 2) return;   // rule d: no chart for ≤2 subtests

    var display    = test.display  || {};
    var themeColor = display.themeColor || "#0d6efd";
    var chartType  = resolveChartType(display, subtests.length);
    var labels     = subtests.map(function(s){ return s.subtest_name; });
    var scores     = subtests.map(function(s){ return Number(s.raw_score) || 0; });
    var ctx        = document.getElementById("chart_" + ti);
    if (!ctx) return;

    switch (chartType) {
        case "radar":
          drawRadarChart(ctx, test.test_name, labels, scores, themeColor);
          break;
        case "pie":
          drawPieChart(ctx, test.test_name, labels, scores, themeColor, subtests);
          break;
        default:
          drawVerticalBarChart(ctx, labels, scores, themeColor, subtests);
    }
  }
  
    /* ── Pie Chart ── */
    function drawPieChart(ctx, testName, labels, scores, themeColor, subtests) {
      // Generates different opacity steps for slices so they are distinguishable
      const backgroundColors = scores.map((_, i) => {
        const opacity = 0.9 - (i * 0.15) > 0.2 ? 0.9 - (i * 0.15) : 0.2;
        return hexToRgba(themeColor, opacity);
      });

      new Chart(ctx, {
        type: "pie",
        data: {
          labels: labels,
          datasets: [{
            label:           "Score",
            data:            scores,
            backgroundColor: backgroundColors,
            borderColor:     "#ffffff",
            borderWidth:     2
          }]
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: {
            legend: {
              display: true,
              position: "bottom",
              labels: { font: { size: 9 }, boxWidth: 12 }
            },
            tooltip: {
              callbacks: {
                title: function(items){ return (subtests[items[0].dataIndex] || {}).subtest_name || ""; },
                label: function(item){ return " Score: " + item.raw; }
              }
            }
          }
        }
      });
    }
  
  /* ── Radar ── */
  function drawRadarChart(ctx, testName, labels, scores, themeColor) {
    new Chart(ctx, {
      type: "radar",
      data: {
        labels: labels,
        datasets: [{
          label:                testName,
          data:                 scores,
          backgroundColor:      hexToRgba(themeColor, 0.12),
          borderColor:          themeColor,
          pointBackgroundColor: themeColor,
          pointRadius:          3,
          borderWidth:          2
        }]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        scales: {
          r: {
            beginAtZero: true,
            ticks:       { stepSize: 5, font: { size: 9 } },
            pointLabels: { font: { size: 9 } }
          }
        },
        plugins: { legend: { display: false } }
      }
    });
  }

  /* ── Vertical bar — fixed medium bar width (rule c) ── */
  function drawVerticalBarChart(ctx, labels, scores, themeColor, subtests) {
    new Chart(ctx, {
      type: "bar",
      data: {
        labels: labels,
        datasets: [{
          label:           "Score",
          data:            scores,
          backgroundColor: hexToRgba(themeColor, 0.75),
          borderColor:     themeColor,
          borderWidth:     1.5,
          borderRadius:    4,
          borderSkipped:   false,
          barThickness:    28   /* fixed medium width — not auto-sized */
        }]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        scales: {
          x: {
            ticks: { font: { size: 9 } },
            grid:  { display: false }
          },
          y: {
            beginAtZero: true,
            ticks: { stepSize: 5, font: { size: 9 } }
          }
        },
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              title: function(items){ return (subtests[items[0].dataIndex] || {}).subtest_name || ""; },
              label: function(item){ return " Score: " + item.raw; }
            }
          }
        }
      }
    });
  }

  /* ═══════════════════════════════════════════════════════════════
     MAIN LOAD
  ═══════════════════════════════════════════════════════════════ */
  async function load() {
    if (!reportToken || !reportToken.startsWith("rt_")) return;

    try {
      var res  = await fetch("/api/print-results?rt=" + encodeURIComponent(reportToken));
      var data = await res.json();
      if (data.error) throw new Error(data.error);

      var profile = data.profile || {};
      var tests   = data.results || [];
      var root    = document.getElementById("reportRoot");

      /* 1 — Cover */
      root.appendChild(buildCoverPage(profile));

      /* 2 — Summary + guidance */
      if (tests.length) {
        root.appendChild(buildSummaryPage(tests, profile.name));
      }

      /* 3 — One page per test */
      if (!tests.length) {
        var empty = document.createElement("section");
        empty.className = "page";
        empty.innerHTML = pageHeaderHTML(profile.name);
        var emptyBody = document.createElement("div");
        emptyBody.className = "page-body";
        emptyBody.innerHTML = "<p style='color:#6c757d;padding-top:24px;'>No results available yet. Please check back shortly.</p>";
        empty.appendChild(emptyBody);
        empty.insertAdjacentHTML("beforeend", PAGE_FOOTER_HTML);
        root.appendChild(empty);
      } else {
        tests.forEach(function(test, ti) {
          root.appendChild(buildTestPage(test, ti, profile.name));
        });
      }

      /* 4 — Show report */
      document.getElementById("loadingState").style.display = "none";
      root.style.display = "block";

      /* 5 — Draw charts after DOM is ready */
      await new Promise(function(resolve){ setTimeout(resolve, 60); });
      tests.forEach(function(test, ti) {
        drawCharts(test, ti);
      });

    } catch (err) {
      document.getElementById("loadingState").style.display = "none";
      var errEl = document.getElementById("errorState");
      errEl.style.display = "block";

      var msg      = err.message || "";
      var friendly = "Failed to load report. Please try again or contact support.";
      if (msg.includes("not found"))      friendly = "This report link is invalid or has been removed.";
      if (msg.includes("No results"))     friendly = "Your results are still being processed. Please try again in a few minutes.";
      if (msg.includes("column missing")) friendly = "Report system configuration error. Please contact support.";

      errEl.innerHTML =
        "<p style='text-align:center;padding:60px 20px;color:#6c757d;'>" +
          "<strong style='display:block;font-size:1.1rem;margin-bottom:8px;color:#1a1a2e;'>Could not load report</strong>" +
          friendly + "<br/><br/>" +
          "<a href='mailto:successtepsnlpa@gmail.com' style='color:#0d6efd;'>successtepsnlpa@gmail.com</a>" +
        "</p>";
    }
  }

  load();
  </script>

