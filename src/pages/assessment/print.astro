---
// src/pages/print.astro
// Permanent, shareable, configurable report page.
// Access: /print?rt=rt_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
//
// Per-test display is driven by the "Test_Display_Config" sheet in GAS:
//   Image_URL      → test header image (path in /public or full https URL)
//   Chart_Type     → bar_vertical | radar | bar_horizontal 
//   Theme_Color    → hex colour for the test band and chart
//   Subtest_Layout → side_image | cards | full_width
//   Section_Color  → light background tint for the test band

export const prerender = false;

import { Image } from 'astro:assets';
//import pdfMain from '../../images/pdf_Front1.jpg';
import LOGO    from '../../images/fitLogo.png';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Assessment Report | Success Steps</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/print-report.css" />
</head>

<body>

  <!-- Screen toolbar (hidden on print via CSS) -->
  <div class="screen-toolbar">
    <a href="/" class="btn-back">← Home</a>
    <h1>Success Steps — Assessment Report</h1>
    <button class="btn-print" onclick="window.print()">🖨️ Save as PDF / Print</button>
  </div>

  <div class="print-shell">
    <div class="report-paper">

      <div id="loadingState">
        <div class="spinner"></div>
        <p>Loading your report…</p>
      </div>
      <div id="errorState"></div>

      <!-- Astro-resolved image paths exposed to client JS via data attributes -->
      <span id="__logoSrc"     data-src={LOGO.src}    style="display:none"></span>
      <span id="__coverImgSrc" data-src=/images/pdfreport/brain-mapping-neurosience.webp  style="display:none"></span>

      <!-- All pages injected here by JS -->
      <div id="reportRoot" style="display:none;"></div>

    </div>
  </div>


  <script is:inline>
  /* ═══════════════════════════════════════════════════════════════
     PALETTE — fallback colours when no theme is configured
  ═══════════════════════════════════════════════════════════════ */
  var DEFAULT_COLOURS = [
    "#0d6efd","#0dcaf0","#20c997","#ffc107",
    "#fd7e14","#6f42c1","#d63384","#198754","#dc3545","#6c757d"
  ];

  /* ═══════════════════════════════════════════════════════════════
     LEVEL LABEL → PILL COLOUR MAP
     Each label has a fixed semantic colour regardless of test theme.
     Groups:
       Red family    — needs improvement / low / high dependency
       Amber family  — below avg / developing / room for improvement
       Blue family   — average / progressing / moderate
       Teal/green    — above avg / proficiency / balanced
       Emerald       — strong / excelling / competing
       Purple        — exceptional / outstanding / mastery
     Brain dominance labels get a dedicated indigo/violet pair.
  ═══════════════════════════════════════════════════════════════ */
  var LEVEL_COLOURS = {
    // ── Needs improvement tier ──
    "Needs Significant Improvement": "#c0392b",
    "Needs Improvement":             "#e74c3c",
    "Room for Improvement":          "#e67e22",

    // ── Below / Low tier ──
    "Below Average":                 "#d35400",
    "Low":                           "#e74c3c",
    "Low Dependency":                "#27ae60",   // low dependency = good

    // ── Developing / Mild tier ──
    "Developing":                    "#e67e22",
    "Developing Skills":             "#e67e22",
    "Mild":                          "#f39c12",

    // ── Average / Moderate tier ──
    "Average":                       "#2980b9",
    "Moderate":                      "#f39c12",
    "Moderate Dependency":           "#f39c12",
    "Moderate-Low Dependency":       "#27ae60",   // leaning low = better
    "Moderate-High Dependency":      "#e67e22",   // leaning high = worse
    "Progressing":                   "#2980b9",

    // ── Above average / basic proficiency ──
    "Above Average":                 "#16a085",
    "Basic Proficiency":             "#16a085",

    // ── Competing / High Dependency ──
    "Competing":                     "#1abc9c",
    "High Dependency":               "#c0392b",   // high dependency = bad
    "High":                          "#c0392b",

    // ── Strong / Proficiency ──
    "Strong Proficiency":            "#27ae60",
    "Excelling":                     "#27ae60",

    // ── Excellent / Exceptional ──
    "Excellent":                     "#8e44ad",
    "Exceptional Mastery":           "#6c3483",
    "Outstanding":                   "#6c3483",

    // ── Brain dominance — L.B ──
    "Limited L.B Dominance":         "#7f8c8d",
    "Developing L.B Dominance":      "#2471a3",
    "Balanced L.B Dominance":        "#1a5276",
    "Strong L.B Dominance":          "#154360",

    // ── Brain dominance — R.B ──
    "Limited R.B Dominance":         "#7f8c8d",
    "Developing R.B Dominance":      "#76448a",
    "Balanced R.B Dominance":        "#6c3483",
    "Strong R.B Dominance":          "#4a235a"
  };

  /** Returns the fixed pill colour for a level label, or a neutral grey fallback */
  function levelColour(label) {
    return LEVEL_COLOURS[label] || "#6c757d";
  }

  /* ═══════════════════════════════════════════════════════════════
     REPORT TOKEN
  ═══════════════════════════════════════════════════════════════ */
  var params      = new URLSearchParams(window.location.search);
  var reportToken = params.get("rt");

  if (!reportToken || !reportToken.startsWith("rt_")) {
    document.getElementById("loadingState").style.display = "none";
    var errEl = document.getElementById("errorState");
    errEl.style.display = "block";
    errEl.innerHTML =
      "<p style='text-align:center;padding:60px 20px;color:#6c757d;'>" +
        "<strong style='display:block;font-size:1.1rem;margin-bottom:8px;color:#1a1a2e;'>Invalid Report Link</strong>" +
        "This link is missing or incorrect. Please use the link provided on your " +
        "assessment completion page, or contact " +
        "<a href='mailto:successtepsnlpa@gmail.com'>successtepsnlpa@gmail.com</a>." +
      "</p>";
  }

  /* ═══════════════════════════════════════════════════════════════
     IMAGE SRCS
  ═══════════════════════════════════════════════════════════════ */
  var LOGO_SRC      = document.getElementById("__logoSrc").dataset.src;
  var COVER_IMG_SRC = document.getElementById("__coverImgSrc").dataset.src;

  /* ═══════════════════════════════════════════════════════════════
     DATE
  ═══════════════════════════════════════════════════════════════ */
  var now      = new Date();
  var genLabel = "Generated " + now.toLocaleDateString("en-GB", {
    day: "numeric", month: "long", year: "numeric"
  });

  /* ═══════════════════════════════════════════════════════════════
     SHARED: PAGE HEADER
  ═══════════════════════════════════════════════════════════════ */
  function pageHeaderHTML(name) {
    return '<div class="page-header">' +
      '<div class="header-brand">' +
        '<img src="' + LOGO_SRC + '" alt="Success Steps" height="32" />' +
        '<span class="header-site">www.successsteps.in</span>' +
      '</div>' +
      '<div class="header-right">' +
        '<span class="header-report-type">Psychometric Assessment</span>' +
        '<span class="header-name">' + (name || "—") + '</span>' +
        '<span class="header-date">' + genLabel + '</span>' +
      '</div>' +
    '</div>';
  }

  /* ═══════════════════════════════════════════════════════════════
     SHARED: PAGE FOOTER
  ═══════════════════════════════════════════════════════════════ */
  var PAGE_FOOTER_HTML =
    '<div class="page-footer">' +
      '<span class="footer-left">Dr. Antony Augusthy · Neurocognitive Psychologist</span>' +
      '<span class="footer-center">Success Steps NLP Academy · successtepsnlpa@gmail.com</span>' +
      '<span class="footer-confidential">Confidential</span>' +
    '</div>';

  /* ═══════════════════════════════════════════════════════════════
     HELPER: lighten a hex colour for the section background
  ═══════════════════════════════════════════════════════════════ */
  function hexToRgba(hex, alpha) {
    var r = parseInt(hex.slice(1,3), 16);
    var g = parseInt(hex.slice(3,5), 16);
    var b = parseInt(hex.slice(5,7), 16);
    return "rgba(" + r + "," + g + "," + b + "," + alpha + ")";
  }



  /* ═══════════════════════════════════════════════════════════════
     PAGE 1 — COVER
  ═══════════════════════════════════════════════════════════════ */
  function buildCoverPage(profile) {
    var name     = profile.name      || "—";
    var email    = profile.email     || "—";
    var gender   = profile.gender    || "—";
    var age      = profile.age       || "—";
    var testedOn = profile.createdAt
      ? new Date(profile.createdAt).toLocaleDateString("en-GB", {
          day: "numeric", month: "long", year: "numeric" })
      : "—";

    var sec = document.createElement("section");
    sec.className = "page cover";
    sec.innerHTML =
      '<div class="cover-topbar">' +
        '<div class="cover-topbar-brand">' +
          '<img src="' + LOGO_SRC + '" alt="Success Steps NLP Academy" height="42" />' +
          '<span class="cover-topbar-url">www.successsteps.in</span>' +
        '</div>' +
        '<span class="cover-topbar-confidential">Confidential</span>' +
      '</div>' +

      '<div class="cover-title-band">' +
        '<div class="cover-report-label">Psychometric Assessment Report</div>' +
        '<h1>Understanding Your<br/><em>Mind &amp; Potential</em></h1>' +
      '</div>' +

      '<div class="cover-image-wrap">' +
        '<img src="' + COVER_IMG_SRC + '" alt="Assessment Report Cover" />' +
      '</div>' +

      '<div class="cover-meta-strip">' +
        '<div class="cover-meta-item"><div class="cover-meta-label">Name</div><div class="cover-meta-value">' + name + '</div></div>' +
        '<div class="cover-meta-item"><div class="cover-meta-label">Gender / Age</div><div class="cover-meta-value">' + gender + ' / ' + age + '</div></div>' +
        '<div class="cover-meta-item"><div class="cover-meta-label">Email</div><div class="cover-meta-value">' + email + '</div></div>' +
        '<div class="cover-meta-item"><div class="cover-meta-label">Tested On</div><div class="cover-meta-value">' + testedOn + '</div></div>' +
      '</div>' +

      '<div class="cover-taxonomy">' +
        '<h2>Neuro-Cognitive · Emotional Intelligence<br/>Behaviour Competency Mapping</h2>' +
      '</div>' +

      '<div class="cover-analyst">' +
        '<div class="cover-analyst-avatar">🧠</div>' +
        '<div class="cover-analyst-info">' +
          '<div class="cover-analyst-by">Test Analysis &amp; Brain Mapping by</div>' +
          '<div class="cover-analyst-name">Dr. Antony Augusthy</div>' +
          '<div class="cover-analyst-title">Neurocognitive Psychologist · NLP Master Practitioner Trainer</div>' +
        '</div>' +
      '</div>' +

      '<div class="cover-credentials">' +
        '<span class="cover-cred-pill">ABNLP · USA</span>' +
        '<span class="cover-cred-pill">ICF Executive Coach</span>' +
        '<span class="cover-cred-pill">IAOTH · UK</span>' +
        '<span class="cover-cred-pill">25+ International Certifications</span>' +
      '</div>' +

      '<div class="cover-bottombar">' +
        '<span>Success Steps NLP Academy, Thane, Mumbai</span>' +
        '<span>' + genLabel + '</span>' +
      '</div>';

    return sec;
  }

  /* ═══════════════════════════════════════════════════════════════
     PAGE 2 — SUMMARY + GUIDANCE NOTE
  ═══════════════════════════════════════════════════════════════ */
  function buildSummaryPage(tests, name, careerPicks) {
    var tableRows = tests.map(function(test, i) {
      var subtests    = test.subtests || [];
      var maxPossible = subtests.reduce(function(s, st){ return s + (Number(st.max_score) || 0); }, 0);
      var totalScore  = subtests.reduce(function(s, st){ return s + (Number(st.raw_score) || 0); }, 0);
      var pct         = maxPossible > 0 ? Math.round((totalScore / maxPossible) * 100) : 0;
      var themeColor  = (test.display && test.display.themeColor) || "#0d6efd";
      return '<tr>' +
        '<td><span class="summary-sn" style="background:' + themeColor + '">' + (i + 1) + '</span></td>' +
        '<td style="font-weight:600;">' + test.test_name + '</td>' +
        '<td>' + subtests.length + ' subtest' + (subtests.length !== 1 ? 's' : '') + '</td>' +
        '<td><span class="summary-score-badge" style="background:' + hexToRgba(themeColor, 0.1) + ';color:' + themeColor + '">' +
          totalScore + ' / ' + maxPossible + ' &nbsp;·&nbsp; ' + pct + '%' +
        '</span></td>' +
      '</tr>';
    }).join("");

    var sec = document.createElement("section");
    sec.className = "page";
    sec.innerHTML = pageHeaderHTML(name);

    var body = document.createElement("div");
    body.className = "page-body";
    body.innerHTML =
      '<h2 class="section-title">Assessment Overview</h2>' +
      '<p class="summary-intro">The following assessments were conducted as part of your personalised psychometric evaluation. Each test is detailed in the pages that follow, with subtest breakdowns, scores, and individual feedback.</p>' +
      '<table class="summary-table">' +
        '<thead><tr><th style="width:44px;">#</th><th>Assessment</th><th>Subtests</th><th>Score</th></tr></thead>' +
        '<tbody>' + tableRows + '</tbody>' +
      '</table>' +
      buildCareerPicksHTML(careerPicks);

    sec.appendChild(body);
    sec.insertAdjacentHTML("beforeend", PAGE_FOOTER_HTML);
    return sec;
  }
  /* ═══════════════════════════════════════════════════════════════
    PAGE 3 — GUIDANCE NOTE (own page)
  ═══════════════════════════════════════════════════════════════ */
  function buildGuidancePage(name) {
    var sec = document.createElement("section");
    sec.className = "page";
    sec.innerHTML = pageHeaderHTML(name);

    var body = document.createElement("div");
    body.className = "page-body";
    body.innerHTML =
      '<h2 class="section-title">For Students, Parents &amp; Teachers</h2>' +
      '<div class="guidance-card">' +
        '<div class="guidance-header">' +
          '<div class="guidance-icon">💙</div>' +
          '<div class="guidance-title">' +
            '<span>A note for</span>Students · Parents · Teachers' +
          '</div>' +
        '</div>' +
        '<div class="guidance-body">' +
          '<p>We warmly encourage parents and teachers to carefully read and reflect on ' +
          'this report before initiating any conversation with their child or student. ' +
          'This assessment is not a measure of worth — it is a map of ' +
          '<strong>inner strengths, hidden talents, and areas of growth</strong> ' +
          'waiting to be nurtured.</p>' +
          '<p>Please use the insights shared here to build a ' +
          '<strong>supportive, stress-free environment</strong> — one where your child ' +
          'feels safe to explore, question, and discover who they truly are. Avoid ' +
          'comparing scores or outcomes with others; every profile is unique and ' +
          'equally valuable.</p>' +
          '<p>If questions arise, our team is available to walk you through the findings ' +
          'in a one-to-one counselling session so the report translates into meaningful, ' +
          'positive action for your child.</p>' +
        '</div>' +
        '<div class="guidance-sign">' +
          '<div>' +
            '<div class="guidance-sign-name">Dr. Antony Augusthy</div>' +
            '<div class="guidance-sign-title">' +
              'Neurocognitive Psychologist · Success Steps NLP Academy' +
            '</div>' +
          '</div>' +
          '<div class="guidance-wishes">🌟 Wishing you and your child every success!</div>' +
        '</div>' +
      '</div>';

    sec.appendChild(body);
    sec.insertAdjacentHTML("beforeend", PAGE_FOOTER_HTML);
    return sec;
  }
  /* ═══════════════════════════════════════════════════════════════
   CAREER PICKS SECTION — rendered inside buildSummaryPage()
   Shows the student's 10 chosen professions grouped by category,
   connecting their aspirations to MIQ intelligence domains.
  ═══════════════════════════════════════════════════════════════ */
  function buildCareerPicksHTML(careerPicks) {
    if (!careerPicks || !careerPicks.length) return "";

    // Group picks by category
    var grouped = {};
    var order   = [];   // preserve insertion order
    careerPicks.forEach(function(pick) {
      var cat = pick.category || "Other";
      if (!grouped[cat]) { grouped[cat] = []; order.push(cat); }
      grouped[cat].push(pick.profession);
    });

    // Category → accent colour (maps loosely to intelligence types)
    var CAT_COLOURS = {
      "Linguistic":      "#0d6efd",
      "Logical":         "#0dcaf0",
      "Spatial":         "#6f42c1",
      "Musical":         "#d63384",
      "Kinesthetic":     "#fd7e14",
      "Naturalist":      "#198754",
      "Interpersonal":   "#20c997",
      "Intrapersonal":   "#6c757d",
      "Existential":     "#0a2342",
      "Other":           "#adb5bd"
    };

    // Build one pill per profession
    var pillsHTML = careerPicks.map(function(pick) {
      var colour = CAT_COLOURS[pick.category] || CAT_COLOURS["Other"];
      return (
        '<div class="cop-pill" style="border-color:' + colour + '">' +
          '<span class="cop-pill-name">' + pick.profession + '</span>' +
          '<span class="cop-pill-cat" style="color:' + colour + '">' +
            pick.category +
          '</span>' +
        '</div>'
      );
    }).join("");

    // Build category legend dots
    var legendHTML = order.map(function(cat) {
      var colour = CAT_COLOURS[cat] || CAT_COLOURS["Other"];
      var count  = grouped[cat].length;
      return (
        '<span class="cop-legend-item">' +
          '<span class="cop-legend-dot" style="background:' + colour + '"></span>' +
          cat + ' (' + count + ')' +
        '</span>'
      );
    }).join("");

    return (
      '<div class="cop-section">' +

        /* Header */
        '<div class="cop-header">' +
          '<div class="cop-header-left">' +
            '<div class="cop-icon">🎯</div>' +
            '<div>' +
              '<div class="cop-title">Career Aspirations</div>' +
              '<div class="cop-subtitle">' +
                'The student\'s top ' + careerPicks.length +
                ' profession choices — grouped by intelligence domain' +
              '</div>' +
            '</div>' +
          '</div>' +
          '<span class="cop-count-badge">' +
            careerPicks.length + ' selected' +
          '</span>' +
        '</div>' +

        /* Profession pills grid */
        '<div class="cop-pills-grid">' + pillsHTML + '</div>' +

        /* Category legend */
        '<div class="cop-legend">' + legendHTML + '</div>' +

      '</div>'
    );
  }
  /* ═══════════════════════════════════════════════════════════════
     SUBTEST RENDERERS — three layout modes
  ═══════════════════════════════════════════════════════════════ */

  /* cards — original grid layout (default) */
  function renderSubtestsCards(subtests, themeColor) {
    var grid = document.createElement("div");
    grid.className = "subtests-grid";
    subtests.forEach(function(st, si) {
      var colour = themeColor || DEFAULT_COLOURS[si % DEFAULT_COLOURS.length];
      var maxS   = Number(st.max_score) || 1;
      var rawS   = Number(st.raw_score) || 0;
      var pct    = Math.min(100, Math.round((rawS / maxS) * 100));

      var card = document.createElement("div");
      card.className = "subtest-card";
      card.style.borderLeftColor = colour;
      card.innerHTML =
        '<div class="subtest-card-header">' +
          '<h4>' + st.subtest_name + '</h4>' +
          '<span class="level-pill" style="background:' + levelColour(st.level_label) + '">' + (st.level_label || "—") + '</span>' +
        '</div>' +
        '<div class="subtest-score">' +
          'Score: <strong>' + st.raw_score + '</strong>' +
          '<span style="color:#adb5bd"> / ' + st.max_score + '</span>' +
          '&nbsp;<span style="color:#adb5bd">(' + st.score_range + ')</span>' +
        '</div>' +
        '<div class="score-mini-bar-wrap"><div class="score-mini-bar" style="width:' + pct + '%;background:' + colour + '"></div></div>' +
        '<ul class="subtest-feedback-list" style="--bullet-color:' + colour + '">' + linesToListItems(st.feedback) + '</ul>';
      grid.appendChild(card);
    });
    return grid;
  }

  /* ─────────────────────────────────────────────────────────────
     HELPER: parse feedback string into <li> bullet items.
     GAS feedback uses "• " as separator between points.
  ───────────────────────────────────────────────────────────── */
  function feedbackToBullets(feedbackRaw) {
    if (!feedbackRaw) return "<li>—</li>";
    var parts = feedbackRaw
      .split("•")
      .map(function(s){ return s.trim(); })
      .filter(function(s){ return s.length > 0; });
    if (parts.length === 0) return "<li>" + feedbackRaw + "</li>";
    return parts.map(function(p){ return "<li>" + p + "</li>"; }).join("");
  }

  /* ─────────────────────────────────────────────────────────────
     HELPER: parse a raw feedback string into three structured
     sections — Feedback, Career Suggestions, Characteristics —
     so each can be displayed under its own heading.

     The GAS feedback text follows the loose pattern:
       "<intro/feedback sentences> Career Suggestions: A, B, etc.
        <Subject> Characteristics: • point one• point two• ..."

     Detection is done with case-insensitive markers so it degrades
     gracefully (whole string becomes "feedback" with bullets) when
     a particular subtest's text doesn't follow the pattern.
  ───────────────────────────────────────────────────────────── */
  function parseFeedbackSections(feedbackRaw) {
    var result = { feedback: "", career: "", characteristics: "" };
    if (!feedbackRaw) return result;

    var text = feedbackRaw.trim();

    // Locate "Career Suggestions:" (case-insensitive)
    var careerMatch = /career\s+suggestions\s*:/i.exec(text);
    // Locate "...Characteristics:" — matches "Visual/spatial Characteristics:",
    // "Characteristics:", etc. — i.e. an optional short label before the word.
    var charMatch = /([A-Za-z\/\-\s]{0,40}characteristics\s*:)/i.exec(text);

    var careerIdx = careerMatch ? careerMatch.index : -1;
    var charIdx   = charMatch   ? charMatch.index   : -1;

    // Feedback = everything before the first marker found
    var firstCut = text.length;
    if (careerIdx !== -1) firstCut = Math.min(firstCut, careerIdx);
    if (charIdx   !== -1) firstCut = Math.min(firstCut, charIdx);
    result.feedback = text.slice(0, firstCut).trim();
    // Strip a redundant leading "Feedback:" label since the card already
    // renders its own "FEEDBACK" section heading above this text.
    result.feedback = result.feedback.replace(/^feedback\s*:\s*/i, "");

    // Career Suggestions = text between its marker and the next marker (characteristics, if it comes after)
    if (careerIdx !== -1) {
      var careerStart = careerIdx + careerMatch[0].length;
      var careerEnd   = (charIdx !== -1 && charIdx > careerIdx) ? charIdx : text.length;
      result.career = text.slice(careerStart, careerEnd).trim();
    }

    // Characteristics = everything after its marker to the end
    if (charIdx !== -1) {
      var charStart = charIdx + charMatch[0].length;
      result.characteristics = text.slice(charStart).trim();
    }

    // Fallback: nothing matched any marker → whole text is "feedback"
    if (!result.feedback && !result.career && !result.characteristics) {
      result.feedback = text;
    }

    return result;
  }

  /* ─────────────────────────────────────────────────────────────
     HELPER: split a block of text into sentence-level lines so each
     sentence renders on its own line. Used for the Feedback and
     Characteristics sections.

     If the text contains "•" separators, it's split on those first
     (each GAS-authored bullet point may itself contain several
     sentences), then each resulting chunk is further split into
     individual sentences. Plain text with no "•" markers is split
     straight into sentences.
  ───────────────────────────────────────────────────────────── */
  function splitIntoSentences(chunk) {
    var text = chunk.trim();
    if (!text) return [];
    var sentences = text.match(/[^.!?]+[.!?]+(?=\s+|$)/g);
    if (sentences && sentences.length) {
      return sentences.map(function(s){ return s.trim(); }).filter(Boolean);
    }
    return [text];
  }

  function textToLines(raw) {
    if (!raw) return [];
    var text = raw.trim();
    if (!text) return [];

    var chunks = text.indexOf("•") !== -1
      ? text.split("•").map(function(s){ return s.trim(); }).filter(function(s){ return s.length > 0; })
      : [text];

    var lines = [];
    chunks.forEach(function(chunk) {
      splitIntoSentences(chunk).forEach(function(s) { lines.push(s); });
    });
    return lines;
  }

  function linesToListItems(raw) {
    var lines = textToLines(raw);
    if (!lines.length) return "<li>—</li>";
    return lines.map(function(l){ return "<li>" + l + "</li>"; }).join("");
  }

  /* side_image layout
     ┌─────────────────────────────────────────────────────┐
     │  Subtest name                       [Level pill]    │  full-width header
     │  Score: X / Y  (range)  [mini bar]                 │  full-width score row
     ├─────────────────────┬───────────────────────────────┤
     │                     │  Feedback                     │
     │     IMAGE  50%      │  • Bullet one          50%    │
     │                     │  • Bullet two                 │
     └─────────────────────┴───────────────────────────────┘
     One card per row — no grid wrapping.

     NOTE: this 50/50 split is now used only as the fallback layout for
     "narrow" images (e.g. Left/Right Brain art) that would look
     stretched or leave excess empty space if forced full-width.

     The new DEFAULT layout (built inline below, for images whose
     natural aspect ratio is wide enough) is "stacked":
       ┌─────────────────────────────────────────────────────┐
       │  Subtest name                       [Level pill]    │  header
       │  Score: X / Y  (range)  [mini bar]                  │
       ├─────────────────────────────────────────────────────┤
       │              IMAGE — full width, medium height       │  (skipped if no image)
       ├─────────────────────────────────────────────────────┤
       │  FEEDBACK                                            │
       │  Sentence one. Sentence two. ...                     │
       │  CAREER SUGGESTIONS                                  │
       │  Architect, Industrial Designer, etc.                │
       │  CHARACTERISTICS                                     │
       │  Sentence one. Sentence two. ...                     │
       └─────────────────────────────────────────────────────┘
     Which layout applies is decided per-image once its natural size
     is known — see applyNarrowLayout() further down.
  */
  function renderSubtestsSideImage(subtests, themeColor, subtestImageUrls, imageSizePct) {
    var wrap = document.createElement("div");
    wrap.className = "si-cards-wrap";

    subtests.forEach(function(st, si) {
      var colour = themeColor || DEFAULT_COLOURS[si % DEFAULT_COLOURS.length];
      var maxS   = Number(st.max_score) || 1;
      var rawS   = Number(st.raw_score) || 0;
      var pct    = Math.min(100, Math.round((rawS / maxS) * 100));

      // Per-subtest image URL — falls back to blank if not set
      var stImgUrl = (subtestImageUrls[si] || "").trim();

      // Parse the raw feedback into Feedback / Career Suggestions / Characteristics
      var sections = parseFeedbackSections(st.feedback);

      var levelPillHTML = '<span class="level-pill" style="background:' + levelColour(st.level_label) + '">' + (st.level_label || "—") + '</span>';

      var headerHTML =
        '<div class="si-card-top">' +
          '<div class="si-card-header">' +
            '<h4 class="si-subtest-name">' + st.subtest_name + '</h4>' +
            levelPillHTML +
          '</div>' +
          '<div class="si-score-row">' +
            '<span class="si-score-text">' +
              'Score:&nbsp;<strong>' + st.raw_score + '</strong>' +
              '<span style="color:#adb5bd">&nbsp;/&nbsp;' + st.max_score + '</span>' +
              '&nbsp;<span style="color:#adb5bd">(' + (st.score_range || "") + ')</span>' +
            '</span>' +
            '<div class="score-mini-bar-wrap si-bar"><div class="score-mini-bar" style="width:' + pct + '%;background:' + colour + '"></div></div>' +
          '</div>' +
        '</div>';

      // ── Stacked body content: Feedback → Career Suggestions → Characteristics ──
      var stackedSectionsHTML = '';

      // Feedback (bulleted if it had "•" markers, otherwise sentence-per-line)
      stackedSectionsHTML +=
        '<div class="si-subsection">' +
          '<div class="si-subsection-label" style="color:' + colour + '">Feedback</div>' +
          '<ul class="si-bullet-list">' + linesToListItems(sections.feedback) + '</ul>' +
        '</div>';

      // Career Suggestions — short flowing line, not bulleted
      if (sections.career) {
        stackedSectionsHTML +=
          '<div class="si-subsection">' +
            '<div class="si-subsection-label" style="color:' + colour + '">Career Suggestions</div>' +
            '<div class="si-career-text">' + sections.career + '</div>' +
          '</div>';
      }

      // Characteristics — one sentence per line
      if (sections.characteristics) {
        stackedSectionsHTML +=
          '<div class="si-subsection">' +
            '<div class="si-subsection-label" style="color:' + colour + '">Characteristics</div>' +
            '<ul class="si-bullet-list">' + linesToListItems(sections.characteristics) + '</ul>' +
          '</div>';
      }

      // No image at all → stacked layout with no image strip
      if (!stImgUrl) {
        var card = document.createElement("div");
        card.className = "si-card";
        card.style.borderLeftColor = colour;
        card.style.borderTopColor  = colour;
        card.innerHTML = headerHTML +
          '<div class="si-card-body--stacked">' +
            '<div class="si-card-sections">' + stackedSectionsHTML + '</div>' +
          '</div>';
        wrap.appendChild(card);
        return;
      }

      // Has image → build the card now with a full-width image strip by
      // default (stacked layout). Once the image loads, check its natural
      // aspect ratio: narrow/portrait images (e.g. Left/Right Brain art)
      // switch to the original 50/50 side-by-side layout instead, since
      // stretching them full-width would look distorted or leave excess
      // empty space.
      var card = document.createElement("div");
      card.className = "si-card";
      card.style.borderLeftColor = colour;
      card.style.borderTopColor  = colour;

      var bodyStacked = document.createElement("div");
      bodyStacked.className = "si-card-body--stacked";

      var imageStrip = document.createElement("div");
      imageStrip.className = "si-image-full";
      var imgEl = document.createElement("img");
      imgEl.src = stImgUrl;
      imgEl.alt = st.subtest_name;

      // Stamp the image's natural aspect-ratio onto the strip container
      // so @media print doesn't collapse its height across page breaks.
      // On screen, width:100% + height:auto on the img already handles sizing.
      function setStripRatio() {
        if (imgEl.naturalWidth && imgEl.naturalHeight) {
          imageStrip.style.aspectRatio = (imgEl.naturalWidth / imgEl.naturalHeight).toFixed(4);
        }
      }

      imageStrip.appendChild(imgEl);

      var sectionsWrap = document.createElement("div");
      sectionsWrap.className = "si-card-sections";
      sectionsWrap.innerHTML = stackedSectionsHTML;

      bodyStacked.appendChild(imageStrip);
      bodyStacked.appendChild(sectionsWrap);

      card.innerHTML = headerHTML;
      card.appendChild(bodyStacked);
      wrap.appendChild(card);

      // Decide layout once the image's natural size is known.
      // A "narrow" image (tall/portrait, or unusually thin) is swapped to
      // the original 50% image / 50% feedback layout.
      function applyNarrowLayout() {
        var feedbackPct = (100 - imageSizePct) + "%";
        var bodySplit = document.createElement("div");
        bodySplit.className = "si-card-body";
        bodySplit.style.gridTemplateColumns = imageSizePct + "% " + feedbackPct;
        bodySplit.innerHTML =
          '<div class="si-image-half"><div class="si-image-container">' +
            '<img src="' + stImgUrl + '" alt="' + st.subtest_name + '" />' +
          '</div></div>' +
          '<div class="si-feedback-half">' + stackedSectionsHTML + '</div>';
        card.replaceChild(bodySplit, bodyStacked);
      }

      if (imgEl.complete && imgEl.naturalWidth > 0) {
        // Image already in browser cache — handle synchronously
        setStripRatio();
        var ratio = imgEl.naturalWidth / imgEl.naturalHeight;
        if (ratio < 0.85) applyNarrowLayout();
      } else {
        imgEl.addEventListener("load", function() {
          setStripRatio();
          var ratio = imgEl.naturalWidth / imgEl.naturalHeight;
          if (ratio < 0.85) applyNarrowLayout();
        });
        imgEl.addEventListener("error", function() {
          // Broken image → collapse the strip so no empty grey band appears
          imageStrip.style.display = "none";
        });
      }
    });
    return wrap;
  }

  /* full_width — one subtest per full-width row, richer layout */
  function renderSubtestsFullWidth(subtests, themeColor) {
    var wrap = document.createElement("div");
    subtests.forEach(function(st, si) {
      var colour = themeColor || DEFAULT_COLOURS[si % DEFAULT_COLOURS.length];
      var maxS   = Number(st.max_score) || 1;
      var rawS   = Number(st.raw_score) || 0;
      var pct    = Math.min(100, Math.round((rawS / maxS) * 100));

      var row = document.createElement("div");
      row.className = "subtest-full-width";
      row.style.borderLeftColor = colour;
      row.innerHTML =
        '<div class="subtest-fw-header">' +
          '<h4 class="subtest-name-text">' + st.subtest_name + '</h4>' +
          '<span class="level-pill" style="background:' + levelColour(st.level_label) + '">' + (st.level_label || "—") + '</span>' +
        '</div>' +
        '<div class="subtest-fw-score">' +
          'Score: <strong>' + st.raw_score + '</strong>' +
          '<span style="color:#adb5bd"> / ' + st.max_score + '</span>' +
          '&nbsp;<span style="color:#adb5bd">(' + st.score_range + ')</span>' +
        '</div>' +
        '<div class="score-mini-bar-wrap"><div class="score-mini-bar" style="width:' + pct + '%;background:' + colour + '"></div></div>' +
        '<ul class="subtest-feedback-list" style="--bullet-color:' + colour + '">' + linesToListItems(st.feedback) + '</ul>';
      wrap.appendChild(row);
    });
    return wrap;
  }

  /* ─────────────────────────────────────────────────────────────
     WHEEL TABLE — used when test name contains "Wheel"
     Columns: # | Subtest name + feedback | Score
  ───────────────────────────────────────────────────────────── */
  function renderSubtestsWheelTable(subtests, themeColor) {
    var wrap = document.createElement("div");
    wrap.className = "wheel-table-wrap";

    var headerBg = themeColor || "#0d6efd";

    var thead =
      '<thead><tr style="background:' + headerBg + '">' +
        '<th>#</th>' +
        '<th>Wellness Dimensions</th>' +
        '<th style="text-align:right;padding-right:18px;">Score</th>' +
      '</tr></thead>';

    var tbodyRows = subtests.map(function(st, si) {
      var colour  = themeColor || DEFAULT_COLOURS[si % DEFAULT_COLOURS.length];
      var maxS    = Number(st.max_score) || 1;
      var rawS    = Number(st.raw_score) || 0;
      var pct     = Math.min(100, Math.round((rawS / maxS) * 100));
      var level   = st.level_label || "—";
      var feedback = (st.feedback || "—").replace(/\r?\n/g, " ");

      return '<tr>' +
        /* Col 1 — number */
        '<td class="wt-num" style="border-left:4px solid ' + colour + '">' +
          '<span class="wt-num-badge" style="background:' + colour + '">' + (si + 1) + '</span>' +
        '</td>' +
        /* Col 2 — name + feedback */
        '<td class="wt-body">' +
          '<div class="wt-name-row">' +
            '<span class="wt-subtest-name">' + st.subtest_name + '</span>' +
            '<span class="wt-level-pill" style="background:' + levelColour(st.level_label) + '">' + level + '</span>' +
          '</div>' +
          '<div class="wt-feedback">' + feedback + '</div>' +
        '</td>' +
        /* Col 3 — score */
        '<td class="wt-score">' +
          '<div class="wt-score-badge">' +
            '<span class="wt-score-value">' + rawS + '<span style="font-size:0.72rem;font-weight:400;color:var(--grey)"> / ' + st.max_score + '</span></span>' +
            '<span class="wt-score-range">' + (st.score_range || "") + '</span>' +
          '</div>' +
        '</td>' +
      '</tr>';
    }).join("");

    wrap.innerHTML =
      '<table class="wheel-table">' +
        thead +
        '<tbody>' + tbodyRows + '</tbody>' +
      '</table>';

    return wrap;
  }

  /* ═══════════════════════════════════════════════════════════════
     HELPER — resolve chart type (bar_vertical | radar only)
     "auto" → radar if ≥4 subtests, bar_vertical otherwise
     bar_horizontal = horizontal bar chart.
  ═══════════════════════════════════════════════════════════════ */
  function resolveChartType(display, subtestCount) {
    var ct = (display && display.chartType) || "bar_vertical";
    if (ct === "auto")          return subtestCount >= 4 ? "radar" : "bar_vertical";
    return ct;   // "bar_vertical" | "bar_horizontal" | "radar"
  }

  /* ═══════════════════════════════════════════════════════════════
     PAGE 3…N — ONE PAGE PER TEST
     Rules:
       a. No test-image-panel — chart is always full-width below band
       b. Single chart, type from sheet, default bar_vertical
       c. bar_vertical only — fixed medium bar width
       d. ≤2 subtests → no chart row at all
       e. Per-subtest imageUrl from display.subtestImageUrls[]
          blank url for a subtest → falls back to cards style for that card
       f. Image size % from display.imageSizePct (default 45)
  ═══════════════════════════════════════════════════════════════ */
  function buildTestPage(test, ti, name) {
    var subtests         = test.subtests || [];
    var subtests = (test.subtests || []).filter(function(st) {
      return st.subtest_id !== "MIQ09-C9";
    });
    var display          = test.display  || {};
    var themeColor       = display.themeColor       || "#0d6efd";
    var sectionColor     = display.sectionColor     || "#f0f7ff";
    var subtestLayout    = display.subtestLayout    || "cards";
    var chartType        = resolveChartType(display, subtests.length);
    var imageSizePct     = Number(display.imageSizePct) || 45;
    // Per-subtest image URLs: array aligned to subtests array
    var subtestImageUrls = display.subtestImageUrls || [];

    var maxPossible = subtests.reduce(function(s, st){ return s + (Number(st.max_score) || 0); }, 0);
    var totalScore  = subtests.reduce(function(s, st){ return s + (Number(st.raw_score) || 0); }, 0);
    var showChart   = subtests.length > 2;   // rule d: skip chart for ≤2 subtests

    var sec = document.createElement("section");
    sec.className = "page";
    sec.innerHTML = pageHeaderHTML(name);

    var body = document.createElement("div");
    body.className = "page-body";

    /* ── a. Test header band ── */
    var bandDiv = document.createElement("div");
    bandDiv.innerHTML =
      '<div class="test-header-band">' +
        '<div class="test-header-band-color" style="background:' + themeColor + '"></div>' +
        '<div class="test-header-band-content" style="background:' + sectionColor + '">' +
          '<div class="test-header-band-title" style="color:' + themeColor + '">' + test.test_name + '</div>' +
          '<span class="total-badge" style="background:' + themeColor + '">' +
            'Total: ' + totalScore + ' / ' + maxPossible +
          '</span>' +
        '</div>' +
      '</div>';
    body.appendChild(bandDiv);

    /* ── b/c/d. Chart — full-width, single, only when >2 subtests ── */
    if (showChart) {
      var chartDiv = document.createElement("div");
      chartDiv.className = "chart-panel-full";
      chartDiv.innerHTML =
        '<h6>' + (chartType === "radar" ? "Profile Overview" : "Subtest Scores") + '</h6>' +
        '<div class="' + (chartType === "bar_horizontal" ? "chart-wrap-horizontal" : "chart-wrap-vertical") + '"' +
          (chartType === "bar_horizontal" ? ' id="chartWrap_' + ti + '"' : '') + '>' +
          '<canvas id="chart_' + ti + '"></canvas>' +
        '</div>';
      body.appendChild(chartDiv);
    }

    /* ── e/f. Subtest cards ── */
    var subtestSection = document.createElement("div");
    var isWheelTest = test.test_name && test.test_name.toLowerCase().indexOf("wheel") !== -1;
    if (isWheelTest) {
      subtestSection.appendChild(renderSubtestsWheelTable(subtests, themeColor));
    } else if (subtestLayout === "side_image") {
      subtestSection.appendChild(
        renderSubtestsSideImage(subtests, themeColor, subtestImageUrls, imageSizePct)
      );
    } else if (subtestLayout === "full_width") {
      subtestSection.appendChild(renderSubtestsFullWidth(subtests, themeColor));
    } else {
      subtestSection.appendChild(renderSubtestsCards(subtests, themeColor));
    }
    body.appendChild(subtestSection);

    sec.appendChild(body);
    sec.insertAdjacentHTML("beforeend", PAGE_FOOTER_HTML);
    return sec;
  }

  /* ═══════════════════════════════════════════════════════════════
     CHART DRAWING — single chart per test, bar_vertical or radar
  ═══════════════════════════════════════════════════════════════ */
  function drawCharts(test, ti) {
    var subtests   = test.subtests || [];
    if (subtests.length <= 2) return;   // rule d: no chart for ≤2 subtests

    var display    = test.display  || {};
    var themeColor = display.themeColor || "#0d6efd";
    var chartType  = resolveChartType(display, subtests.length);
    var labels     = subtests.map(function(s){ return s.subtest_name; });
    var scores     = subtests.map(function(s){ return Number(s.raw_score) || 0; });
    var ctx        = document.getElementById("chart_" + ti);
    if (!ctx) return;

    switch (chartType) {
        case "radar":
          drawRadarChart(ctx, test.test_name, labels, scores, themeColor);
          break;
        case "bar_horizontal":
          drawHorizontalBarChart(ctx, "chartWrap_" + ti, labels, scores, themeColor, subtests);
          break;
        case "pie":
          drawPieChart(ctx, test.test_name, labels, scores, themeColor, subtests);
          break;
        default:
          drawVerticalBarChart(ctx, labels, scores, themeColor, subtests);
    }
  }
  
    /* ── Pie Chart ── */
    function drawPieChart(ctx, testName, labels, scores, themeColor, subtests) {
      // Generates different opacity steps for slices so they are distinguishable
      const backgroundColors = scores.map((_, i) => {
        const opacity = 0.9 - (i * 0.15) > 0.2 ? 0.9 - (i * 0.15) : 0.2;
        return hexToRgba(themeColor, opacity);
      });

      new Chart(ctx, {
        type: "pie",
        data: {
          labels: labels,
          datasets: [{
            label:           "Score",
            data:            scores,
            backgroundColor: backgroundColors,
            borderColor:     "#ffffff",
            borderWidth:     2
          }]
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: {
            legend: {
              display: true,
              position: "bottom",
              labels: { font: { size: 9 }, boxWidth: 12 }
            },
            tooltip: {
              callbacks: {
                title: function(items){ return (subtests[items[0].dataIndex] || {}).subtest_name || ""; },
                label: function(item){ return " Score: " + item.raw; }
              }
            }
          }
        }
      });
    }
  
  /* ── Radar ── */
  function drawRadarChart(ctx, testName, labels, scores, themeColor) {
    new Chart(ctx, {
      type: "radar",
      data: {
        labels: labels,
        datasets: [{
          label:                testName,
          data:                 scores,
          backgroundColor:      hexToRgba(themeColor, 0.12),
          borderColor:          themeColor,
          pointBackgroundColor: themeColor,
          pointRadius:          3,
          borderWidth:          2
        }]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        scales: {
          r: {
            beginAtZero: true,
            ticks:       { stepSize: 5, font: { size: 9 } },
            pointLabels: { font: { size: 9 } }
          }
        },
        plugins: { legend: { display: false } }
      }
    });
  }

  /* ── Vertical bar — fixed medium bar width (rule c) ── */
  function drawVerticalBarChart(ctx, labels, scores, themeColor, subtests) {
    new Chart(ctx, {
      type: "bar",
      data: {
        labels: labels,
        datasets: [{
          label:           "Score",
          data:            scores,
          backgroundColor: hexToRgba(themeColor, 0.75),
          borderColor:     themeColor,
          borderWidth:     1.5,
          borderRadius:    4,
          borderSkipped:   false,
          barThickness:    28   /* fixed medium width — not auto-sized */
        }]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        scales: {
          x: {
            ticks: { font: { size: 9 } },
            grid:  { display: false }
          },
          y: {
            beginAtZero: true,
            ticks: { stepSize: 5, font: { size: 9 } }
          }
        },
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              title: function(items){ return (subtests[items[0].dataIndex] || {}).subtest_name || ""; },
              label: function(item){ return " Score: " + item.raw; }
            }
          }
        }
      }
    });
  }

  /* ── Horizontal bar ── */
  function drawHorizontalBarChart(ctx, wrapId, labels, scores, themeColor, subtests) {
    /* Height scales with number of subtests: 40px per bar, min 160px */
    var wrap = wrapId ? document.getElementById(wrapId) : null;
    if (wrap) wrap.style.height = Math.max(160, subtests.length * 40) + "px";

    new Chart(ctx, {
      type: "bar",
      data: {
        labels: labels,
        datasets: [{
          data:            scores,
          backgroundColor: hexToRgba(themeColor, 0.75),
          borderColor:     themeColor,
          borderWidth:     1.5,
          borderRadius:    4,
          borderSkipped:   false,
          barThickness:    22   /* fixed medium width for horizontal bars */
        }]
      },
      options: {
        indexAxis: "y",
        responsive: true, maintainAspectRatio: false,
        scales: {
          x: {
            beginAtZero: true,
            ticks: { stepSize: 5, font: { size: 9 } }
          },
          y: {
            ticks: {
              font: { size: 9 },
              callback: function(val, i) {
                var label = (subtests[i] && subtests[i].subtest_name) || "";
                var words = label.split(" ");
                var lines = []; var cur = "";
                words.forEach(function(w) {
                  if ((cur + " " + w).trim().length <= 18) { cur = (cur + " " + w).trim(); }
                  else { if (cur) lines.push(cur); cur = w; }
                });
                if (cur) lines.push(cur);
                return lines;
              }
            },
            grid: { display: false }
          }
        },
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              title: function(items){ return (subtests[items[0].dataIndex] || {}).subtest_name || ""; },
              label: function(item){ return " Score: " + item.raw; }
            }
          }
        }
      }
    });
  }

  /* ═══════════════════════════════════════════════════════════════
     MAIN LOAD
  ═══════════════════════════════════════════════════════════════ */
  async function load() {
    if (!reportToken || !reportToken.startsWith("rt_")) return;

    try {
      var res  = await fetch("/api/print-results?rt=" + encodeURIComponent(reportToken));
      var data = await res.json();
      if (data.error) throw new Error(data.error);

      var profile = data.profile || {};
      var tests   = data.results || [];
      var root    = document.getElementById("reportRoot");

      /* Set document.title → browsers use this as the default PDF filename
         when the user clicks "Save as PDF / Print".
         Format: BrainMapping_<FirstName><DD><Mon><YYYY>
         e.g.   BrainMapping_Martina25Jun2026                              */
      (function setPdfFilename() {
        var firstName = (profile.name || "").split(" ")[0] || "Report";
        var dateStr   = "";
        if (profile.createdAt) {
          var d = new Date(profile.createdAt);
          var months = ["Jan","Feb","Mar","Apr","May","Jun",
                        "Jul","Aug","Sep","Oct","Nov","Dec"];
          dateStr = d.getDate() + months[d.getMonth()] + d.getFullYear();
        }
        document.title = "BrainMapping_" + firstName + dateStr;
      })();

      /* 1 — Cover */
      root.appendChild(buildCoverPage(profile));

      /* 2 — Summary + career picks */
      if (tests.length) {
        root.appendChild(buildSummaryPage(tests, profile.name, data.careerPicks || []));
      }
      /* 3 — Guidance note (own page) */
      root.appendChild(buildGuidancePage(profile.name));

      /* 4 — One page per test */
      if (!tests.length) {
        var empty = document.createElement("section");
        empty.className = "page";
        empty.innerHTML = pageHeaderHTML(profile.name);
        var emptyBody = document.createElement("div");
        emptyBody.className = "page-body";
        emptyBody.innerHTML = "<p style='color:#6c757d;padding-top:24px;'>No results available yet. Please check back shortly.</p>";
        empty.appendChild(emptyBody);
        empty.insertAdjacentHTML("beforeend", PAGE_FOOTER_HTML);
        root.appendChild(empty);
      } else {
        tests.forEach(function(test, ti) {
          root.appendChild(buildTestPage(test, ti, profile.name));
        });
      }

      /* 5 — Show report */
      document.getElementById("loadingState").style.display = "none";
      root.style.display = "block";

      /* 6 — Draw charts after DOM is ready */
      await new Promise(function(resolve){ setTimeout(resolve, 60); });
      tests.forEach(function(test, ti) {
        drawCharts(test, ti);
      });

    } catch (err) {
      document.getElementById("loadingState").style.display = "none";
      var errEl = document.getElementById("errorState");
      errEl.style.display = "block";

      var msg      = err.message || "";
      var friendly = "Failed to load report. Please try again or contact support.";
      if (msg.includes("not found"))      friendly = "This report link is invalid or has been removed.";
      if (msg.includes("No results"))     friendly = "Your results are still being processed. Please try again in a few minutes.";
      if (msg.includes("column missing")) friendly = "Report system configuration error. Please contact support.";

      errEl.innerHTML =
        "<p style='text-align:center;padding:60px 20px;color:#6c757d;'>" +
          "<strong style='display:block;font-size:1.1rem;margin-bottom:8px;color:#1a1a2e;'>Could not load report</strong>" +
          friendly + "<br/><br/>" +
          "<a href='mailto:successtepsnlpa@gmail.com' style='color:#0d6efd;'>successtepsnlpa@gmail.com</a>" +
        "</p>";
    }
  }

  load();
  </script>

</body>
</html>