---
// src/pages/print.astro
// Permanent, shareable report page.
// Access: /print?rt=rt_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
//
// - No sessionStorage required
// - No assessment token in URL
// - Works for users AND admin on any device, any browser
// - The reportToken is the only credential needed
// - Data is fetched from GAS via /api/print-results proxy

export const prerender = false;

import { Image } from 'astro:assets';
import pdfMain from '../../images/pdf_Front1.jpg';
import LOGO from '../../images/fitLogo.png';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Assessment Report | Success Steps</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/print-report.css" />
</head>

<body>

  <!-- ── Screen toolbar (hidden on print) ── -->
  <div class="screen-toolbar">
    <a href="/" class="btn-back">← Home</a>
    <h1>Success Steps — Assessment Report</h1>
    <button class="btn-print" onclick="window.print()">🖨️ Save as PDF / Print</button>
  </div>

  <div class="print-shell">
    <div class="report-paper">

      <!-- Loading state -->
      <div id="loadingState">
        <div class="spinner"></div>
        <p>Loading your report…</p>
      </div>

      <!-- Error state -->
      <div id="errorState"></div>

      <!--
        Hidden data bridges — Astro resolves image paths at build time
        to hashed /assets/… URLs. We expose them via data attributes
        so the client-side JS can read them without importing modules.
      -->
      <span id="__logoSrc"     data-src={LOGO.src}    style="display:none"></span>
      <span id="__coverImgSrc" data-src={pdfMain.src}  style="display:none"></span>

      <!--
        All page sections are built entirely by JS below.
        There are NO static <section> wrappers here — that was
        the root cause of the blank "Assessment Results" page bug.
        JS injects: cover → summary → one page per test → career (if any)
        Each page has its own header and footer in normal document flow.
      -->
      <div id="reportRoot" style="display:none;"></div>

    </div>
  </div>


  <script is:inline>
  /* ═══════════════════════════════════════════════════════════════
     CONSTANTS
  ═══════════════════════════════════════════════════════════════ */
  const COLOURS = [
    "#0d6efd","#0dcaf0","#20c997","#ffc107",
    "#fd7e14","#6f42c1","#d63384","#198754","#dc3545","#6c757d"
  ];

  /* ═══════════════════════════════════════════════════════════════
     REPORT TOKEN — from URL only, no sessionStorage
  ═══════════════════════════════════════════════════════════════ */
  const params      = new URLSearchParams(window.location.search);
  const reportToken = params.get("rt");
    console.log("Report token at line 88:", reportToken);  // Debug log to verify token retrieval
  if (!reportToken || !reportToken.startsWith("rt_")) {
    // No valid token → show friendly error rather than blank page
    document.getElementById("loadingState").style.display = "none";
    const errEl = document.getElementById("errorState");
    errEl.style.display = "block";
    errEl.innerHTML =
      "<p style='text-align:center;padding:60px 20px;color:#6c757d;'>" +
        "<strong style='display:block;font-size:1.1rem;margin-bottom:8px;color:#1a1a2e;'>Invalid Report Link</strong>" +
        "This link is missing or incorrect. Please use the link from your " +
        "assessment completion page or contact " +
        "<a href='mailto:successtepsnlpa@gmail.com'>successtepsnlpa@gmail.com</a>." +
      "</p>";
  }

  /* ═══════════════════════════════════════════════════════════════
     IMAGE SRCS  (resolved at build time by Astro, read here at runtime)
  ═══════════════════════════════════════════════════════════════ */
  const LOGO_SRC      = document.getElementById("__logoSrc").dataset.src;
  const COVER_IMG_SRC = document.getElementById("__coverImgSrc").dataset.src;

  /* ═══════════════════════════════════════════════════════════════
     DATE LABELS
  ═══════════════════════════════════════════════════════════════ */
  const now      = new Date();
  const genLabel = "Generated " + now.toLocaleDateString("en-GB", {
    day: "numeric", month: "long", year: "numeric"
  });

  /* ═══════════════════════════════════════════════════════════════
     SHARED PAGE HEADER HTML
     Appears at the top of every non-cover page.
  ═══════════════════════════════════════════════════════════════ */
  function pageHeaderHTML(name) {
    return `
      <div class="page-header">
        <div class="header-brand">
          <img src="${LOGO_SRC}" alt="Success Steps" height="32" />
          <span class="header-site">www.successsteps.in</span>
        </div>
        <div class="header-right">
          <span class="header-report-type">Psychometric Assessment</span>
          <span class="header-name">${name || "—"}</span>
          <span class="header-date">${genLabel}</span>
        </div>
      </div>`;
  }

  /* ═══════════════════════════════════════════════════════════════
     SHARED PAGE FOOTER HTML
     Appears at the bottom of every non-cover page.
  ═══════════════════════════════════════════════════════════════ */
  const PAGE_FOOTER_HTML = `
    <div class="page-footer">
      <span class="footer-left">Dr. Antony Augusthy · Neurocognitive Psychologist</span>
      <span class="footer-center">Success Steps NLP Academy · successtepsnlpa@gmail.com</span>
      <span class="footer-confidential">Confidential</span>
    </div>`;

  /* ═══════════════════════════════════════════════════════════════
     PAGE 1 — COVER
  ═══════════════════════════════════════════════════════════════ */
  function buildCoverPage(profile) {
    const name     = profile.name      || "—";
    const email    = profile.email     || "—";
    const gender   = profile.gender    || "—";
    const age      = profile.age       || "—";
    const testedOn = profile.createdAt
      ? new Date(profile.createdAt).toLocaleDateString("en-GB", {
          day: "numeric", month: "long", year: "numeric"
        })
      : "—";

    const sec = document.createElement("section");
    sec.className = "page cover";
    sec.innerHTML = `

      <div class="cover-topbar">
        <div class="cover-topbar-brand">
          <img src="${LOGO_SRC}" alt="Success Steps NLP Academy" height="42" />
          <span class="cover-topbar-url">www.successsteps.in</span>
        </div>
        <span class="cover-topbar-confidential">Confidential</span>
      </div>

      <div class="cover-title-band">
        <div class="cover-report-label">Psychometric Assessment Report</div>
        <h1>Understanding Your<br/><em>Mind &amp; Potential</em></h1>
      </div>

      <div class="cover-image-wrap">
        <img src="${COVER_IMG_SRC}" alt="Assessment Report Cover" />
      </div>

      <div class="cover-meta-strip">
        <div class="cover-meta-item">
          <div class="cover-meta-label">Name</div>
          <div class="cover-meta-value">${name}</div>
        </div>
        <div class="cover-meta-item">
          <div class="cover-meta-label">Gender / Age</div>
          <div class="cover-meta-value">${gender} / ${age}</div>
        </div>
        <div class="cover-meta-item">
          <div class="cover-meta-label">Email</div>
          <div class="cover-meta-value">${email}</div>
        </div>
        <div class="cover-meta-item">
          <div class="cover-meta-label">Tested On</div>
          <div class="cover-meta-value">${testedOn}</div>
        </div>
      </div>

      <div class="cover-taxonomy">
        <h2>Neuro-Cognitive · Emotional Intelligence<br/>Behaviour Competency Mapping</h2>
      </div>

      <div class="cover-analyst">
        <div class="cover-analyst-avatar">🧠</div>
        <div class="cover-analyst-info">
          <div class="cover-analyst-by">Test Analysis &amp; Brain Mapping by</div>
          <div class="cover-analyst-name">Dr. Antony Augusthy</div>
          <div class="cover-analyst-title">Neurocognitive Psychologist · NLP Master Practitioner Trainer</div>
        </div>
      </div>

      <div class="cover-credentials">
        <span class="cover-cred-pill">ABNLP · USA</span>
        <span class="cover-cred-pill">ICF Executive Coach</span>
        <span class="cover-cred-pill">IAOTH · UK</span>
        <span class="cover-cred-pill">25+ International Certifications</span>
      </div>

      <div class="cover-bottombar">
        <span>Success Steps NLP Academy, Thane, Mumbai</span>
        <span>${genLabel}</span>
      </div>`;

    return sec;
  }

  /* ═══════════════════════════════════════════════════════════════
     PAGE 2 — SUMMARY  (test index + guidance note)
  ═══════════════════════════════════════════════════════════════ */
  function buildSummaryPage(tests, name) {
    const tableRows = tests.map(function(test, i) {
      const subtests    = test.subtests || [];
      const maxPossible = subtests.reduce(function(s, st){ return s + (Number(st.max_score) || 0); }, 0);
      const totalScore  = subtests.reduce(function(s, st){ return s + (Number(st.raw_score) || 0); }, 0);
      const pct         = maxPossible > 0 ? Math.round((totalScore / maxPossible) * 100) : 0;
      return `
        <tr>
          <td><span class="summary-sn">${i + 1}</span></td>
          <td style="font-weight:600;">${test.test_name}</td>
          <td>${subtests.length} subtest${subtests.length !== 1 ? "s" : ""}</td>
          <td><span class="summary-score-badge">${totalScore} / ${maxPossible} &nbsp;·&nbsp; ${pct}%</span></td>
        </tr>`;
    }).join("");

    const sec = document.createElement("section");
    sec.className = "page";
    sec.innerHTML = pageHeaderHTML(name);

    const body = document.createElement("div");
    body.className = "page-body";
    body.innerHTML = `
      <h2 class="section-title">Assessment Overview</h2>
      <p class="summary-intro">
        The following assessments were conducted as part of your personalised psychometric
        evaluation. Each test is detailed in the pages that follow, with subtest breakdowns,
        scores, and individual feedback.
      </p>

      <table class="summary-table">
        <thead>
          <tr>
            <th style="width:44px;">#</th>
            <th>Assessment</th>
            <th>Subtests</th>
            <th>Score</th>
          </tr>
        </thead>
        <tbody>${tableRows}</tbody>
      </table>

      <div class="guidance-card">
        <div class="guidance-header">
          <div class="guidance-icon">💙</div>
          <div class="guidance-title">
            <span>A note for</span>
            Students · Parents · Teachers
          </div>
        </div>
        <div class="guidance-body">
          <p>
            We warmly encourage parents and teachers to carefully read and reflect on this
            report before initiating any conversation with their child or student.
            This assessment is not a measure of worth — it is a map of <strong>inner strengths,
            hidden talents, and areas of growth</strong> waiting to be nurtured.
          </p>
          <p>
            Please use the insights shared here to build a <strong>supportive, stress-free
            environment</strong> — one where your child feels safe to explore, question, and
            discover who they truly are. Avoid comparing scores or outcomes with others;
            every profile is unique and equally valuable.
          </p>
          <p>
            If questions arise, our team is available to walk you through the findings in a
            one-to-one counselling session so the report translates into meaningful,
            positive action for your child.
          </p>
        </div>
        <div class="guidance-sign">
          <div>
            <div class="guidance-sign-name">Dr. Antony Augusthy</div>
            <div class="guidance-sign-title">Neurocognitive Psychologist · Success Steps NLP Academy</div>
          </div>
          <div class="guidance-wishes">🌟 Wishing you and your child every success!</div>
        </div>
      </div>`;

    sec.appendChild(body);
    sec.insertAdjacentHTML("beforeend", PAGE_FOOTER_HTML);
    return sec;
  }

  /* ═══════════════════════════════════════════════════════════════
     PAGE 3…N — ONE PAGE PER TEST
  ═══════════════════════════════════════════════════════════════ */
  function buildTestPage(test, ti, name) {
    const subtests    = test.subtests || [];
    const maxPossible = subtests.reduce(function(s, st){ return s + (Number(st.max_score) || 0); }, 0);
    const totalScore  = subtests.reduce(function(s, st){ return s + (Number(st.raw_score) || 0); }, 0);

    const sec = document.createElement("section");
    sec.className = "page";
    sec.innerHTML = pageHeaderHTML(name);

    const body = document.createElement("div");
    body.className = "page-body";

    // Test heading + charts
    const testBlock = document.createElement("div");
    testBlock.className = "test-block";
    testBlock.innerHTML = `
      <div class="test-heading">
        <h3>${test.test_name}</h3>
        <span class="total-badge">Total: ${totalScore} / ${maxPossible}</span>
      </div>
      <div class="charts-row">
        <div class="chart-card">
          <h6>Subtests Overview</h6>
          <div class="chart-wrap"><canvas id="radar_${ti}"></canvas></div>
        </div>
        <div class="chart-card">
          <h6>Subtest Scores</h6>
          <div class="chart-wrap" id="barWrap_${ti}"><canvas id="bar_${ti}"></canvas></div>
        </div>
      </div>`;

    // Subtest cards
    const grid = document.createElement("div");
    grid.className = "subtests-grid";
    subtests.forEach(function(st, si) {
      const colour = COLOURS[si % COLOURS.length];
      const card   = document.createElement("div");
      card.className = "subtest-card";
      card.style.borderLeftColor = colour;
      card.innerHTML = `
        <div class="subtest-card-header">
          <h4>${st.subtest_name}</h4>
          <span class="level-pill" style="background:${colour}">${st.level_label || "—"}</span>
        </div>
        <div class="subtest-score">
          Score: <strong>${st.raw_score}</strong>
          <span style="color:#adb5bd"> / ${st.max_score}</span>
          &nbsp;<span style="color:#adb5bd">(${st.score_range})</span>
        </div>
        <div class="subtest-feedback">${st.feedback || "—"}</div>`;
      grid.appendChild(card);
    });

    testBlock.appendChild(grid);
    body.appendChild(testBlock);
    sec.appendChild(body);
    sec.insertAdjacentHTML("beforeend", PAGE_FOOTER_HTML);
    return sec;
  }

  /* ═══════════════════════════════════════════════════════════════
     CHART DRAWING
  ═══════════════════════════════════════════════════════════════ */
  function drawRadar(test, ti) {
    const ctx      = document.getElementById("radar_" + ti);
    if (!ctx) return;
    const subtests = test.subtests || [];
    new Chart(ctx, {
      type: "radar",
      data: {
        labels: subtests.map(function(s){ return s.subtest_name; }),
        datasets: [{
          label:                test.test_name,
          data:                 subtests.map(function(s){ return Number(s.raw_score) || 0; }),
          backgroundColor:      "rgba(13,110,253,0.12)",
          borderColor:          "#0d6efd",
          pointBackgroundColor: "#0d6efd",
          pointRadius:          3,
          borderWidth:          2
        }]
      },
      options: {
        responsive:          true,
        maintainAspectRatio: false,
        scales: {
          r: {
            beginAtZero: true,
            ticks:       { stepSize: 5, font: { size: 9 } },
            pointLabels: { font: { size: 9 } }
          }
        },
        plugins: { legend: { display: false } }
      }
    });
  }

  function drawBar(test, ti) {
    const ctx      = document.getElementById("bar_" + ti);
    if (!ctx) return;
    const subtests = test.subtests || [];

    // Scale height to number of subtests so bars don't get crushed
    const wrap = document.getElementById("barWrap_" + ti);
    if (wrap) wrap.style.height = Math.max(200, subtests.length * 36) + "px";

    new Chart(ctx, {
      type: "bar",
      data: {
        labels: subtests.map(function(s){ return s.subtest_name; }),
        datasets: [{
          data:            subtests.map(function(s){ return Number(s.raw_score) || 0; }),
          backgroundColor: subtests.map(function(_, i){ return COLOURS[i % COLOURS.length]; }),
          borderRadius:    3,
          borderSkipped:   false
        }]
      },
      options: {
        indexAxis:           "y",
        responsive:          true,
        maintainAspectRatio: false,
        scales: {
          x: {
            beginAtZero: true,
            ticks: { stepSize: 5, font: { size: 9 } }
          },
          y: {
            ticks: {
              font: { size: 9 },
              callback: function(val, i) {
                // Wrap long labels onto multiple lines
                const label = (subtests[i] && subtests[i].subtest_name) || "";
                const words = label.split(" ");
                const lines = [];
                let cur     = "";
                words.forEach(function(w) {
                  if ((cur + " " + w).trim().length <= 18) {
                    cur = (cur + " " + w).trim();
                  } else {
                    if (cur) lines.push(cur);
                    cur = w;
                  }
                });
                if (cur) lines.push(cur);
                return lines;
              }
            },
            grid: { display: false }
          }
        },
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              title: function(items){ return (subtests[items[0].dataIndex] || {}).subtest_name || ""; },
              label: function(item){ return " Score: " + item.raw; }
            }
          }
        }
      }
    });
  }

  /* ═══════════════════════════════════════════════════════════════
     MAIN LOAD FUNCTION
  ═══════════════════════════════════════════════════════════════ */
  async function load() {
    // Guard — if no valid token, the error was already shown above
    console.log("Report token at line 484:", reportToken);  // Debug log to verify token retrieval
    if (!reportToken || !reportToken.startsWith("rt_")) return;

    try {
      // Fetch via our Astro proxy — PSYCHO_GAS_URL stays server-side only
      const res  = await fetch("/api/print-results?rt=" + encodeURIComponent(reportToken));
      const data = await res.json();

      if (data.error) throw new Error(data.error);

      const profile = data.profile || {};
      const tests   = data.results || [];
      const root    = document.getElementById("reportRoot");

      // ── 1. Cover page ──────────────────────────────────────────
      root.appendChild(buildCoverPage(profile));

      // ── 2. Summary page (overview table + guidance note) ───────
      if (tests.length) {
        root.appendChild(buildSummaryPage(tests, profile.name));
      }

      // ── 3. One page per test ───────────────────────────────────
      if (!tests.length) {
        const empty = document.createElement("section");
        empty.className = "page";
        empty.innerHTML = pageHeaderHTML(profile.name);
        const emptyBody = document.createElement("div");
        emptyBody.className = "page-body";
        emptyBody.innerHTML = "<p style='color:#6c757d;padding-top:24px;'>No results available yet. Please check back shortly.</p>";
        empty.appendChild(emptyBody);
        empty.insertAdjacentHTML("beforeend", PAGE_FOOTER_HTML);
        root.appendChild(empty);
      } else {
        tests.forEach(function(test, ti) {
          root.appendChild(buildTestPage(test, ti, profile.name));
        });
      }

      // ── 4. Show report, hide loader ────────────────────────────
      document.getElementById("loadingState").style.display = "none";
      root.style.display = "block";

      // ── 5. Draw charts AFTER elements are in the DOM ───────────
      await new Promise(function(resolve){ setTimeout(resolve, 60); });
      tests.forEach(function(test, ti) {
        drawRadar(test, ti);
        drawBar(test, ti);
      });

    } catch (err) {
      document.getElementById("loadingState").style.display = "none";
      const errEl = document.getElementById("errorState");
      errEl.style.display = "block";

      // Friendly messages for known error conditions
      const msg = err.message || "";
      let friendly = "Failed to load report. Please try again or contact support.";
      if (msg.includes("not found"))      friendly = "This report link is invalid or has been removed.";
      if (msg.includes("No results"))     friendly = "Your results are still being processed. Please try again in a few minutes.";
      if (msg.includes("column missing")) friendly = "Report system configuration error. Please contact support.";

      errEl.innerHTML =
        "<p style='text-align:center;padding:60px 20px;color:#6c757d;'>" +
          "<strong style='display:block;font-size:1.1rem;margin-bottom:8px;color:#1a1a2e;'>Could not load report</strong>" +
          friendly + "<br/><br/>" +
          "<a href='mailto:successtepsnlpa@gmail.com' style='color:#0d6efd;'>successtepsnlpa@gmail.com</a>" +
        "</p>";
    }
  }

  load();
  </script>

</body>
</html>