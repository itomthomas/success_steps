---
/* No imports needed */
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Psychometric Test</title>

    <!-- Bootstrap (optional but recommended) -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
  </head>

  <body>
    <section class="container py-5">
      <h1 class="mb-4">Psychometric Assessment</h1>

      <button id="startBtn" class="btn btn-primary mb-3">
        Begin Psychometric Test
      </button>

      <div id="testSelector" class="mb-4" style="display:none;">
        <label for="testDropdown" class="form-label">Select Test</label>
        <select id="testDropdown" class="form-select">
          <option value="">Loading tests...</option>
        </select>
      </div>

      <div id="questionsContainer"></div>
      <div class="accordion" id="subtestAccordion"></div>
    </section>

    <script is:inline>
      
      const regId = sessionStorage.getItem("regId");

      if (!regId) {
        window.location.href = "/register";
      }
      
      const startBtn = document.getElementById("startBtn");
      const selector = document.getElementById("testSelector");
      const dropdown = document.getElementById("testDropdown");
      const questionsContainer = document.getElementById("questionsContainer");

      startBtn.addEventListener("click", async () => {
        selector.style.display = "block";
        await loadTests();
      });

      async function loadTests() {
        const res = await fetch("/api/psychotestlist");
        const tests = await res.json();

        dropdown.innerHTML = `<option value="">-- Select a Test --</option>`;

        tests.forEach(t => {
          const opt = document.createElement("option");
          opt.value = t.test_id;
          opt.textContent = t.test_name;
          dropdown.appendChild(opt);
        });
      }

      dropdown.addEventListener("change", async (e) => {
        console.log("Dropdown changed → value:", e.target.value);
        if (!e.target.value) return;
        await loadTestBundle(e.target.value);
      });

      async function loadTestBundle(testId) {
        questionsContainer.innerHTML = "Loading test...";

        const res = await fetch(`/api/psychotest-bundle?test_id=${testId}`);
        const data = await res.json();

        renderTest(data);
      }

      async function loadQuestions(testId) {
        if (!testId || testId === "undefined") {
          console.warn("Invalid testId, skipping loadQuestions");
          return;
        }
        questionsContainer.innerHTML = "Loading questions...";

        const res = await fetch(`/api/questions?test_id=${testId}`);
        const questions = await res.json();

        questionsContainer.innerHTML = "";
        if (!questions.length) {
          questionsContainer.innerHTML = "<p>No questions found.</p>";
          return;
        }

        questions.forEach((q, i) => {
            questionsContainer.innerHTML += `
              <div class="border rounded p-3 mb-3">
                <p><strong>${i + 1}. ${q.question}</strong></p>

                ${q.options.map((o, j) => `
                  <div class="form-check">
                    <input
                      type="radio"
                      class="form-check-input"
                      name="q${i}"
                      value="${o.score}"
                      id="q${i}_opt${j}"
                    />
                    <label class="form-check-label" for="q${i}_opt${j}">
                      ${o.label}
                    </label>
                  </div>
                `).join("")}

              </div>
            `;
          });
      }
      
      function renderTest(data) {
        questionsContainer.innerHTML = "";
        const container = document.getElementById("subtestAccordion");
        container.innerHTML = "";

        let qNo = 1;

        data.subtests.forEach((subtest, index) => {
          const isOpen = index === 0; // first accordion open

          const subtestQuestions = data.questions.filter(
            q => q.subtest_code === subtest.subtest_code
          );

          container.innerHTML += `
            <div class="accordion-item">
              <h2 class="accordion-header" id="heading_${subtest.subtest_code}">
                <button
                  class="accordion-button ${isOpen ? "" : "collapsed"}"
                  type="button"
                  data-bs-toggle="collapse"
                  data-bs-target="#collapse_${subtest.subtest_code}"
                  aria-expanded="${isOpen}"
                  aria-controls="collapse_${subtest.subtest_code}"
                >
                  ${subtest.subtest_name}
                </button>
              </h2>

              <div
                id="collapse_${subtest.subtest_code}"
                class="accordion-collapse collapse ${isOpen ? "show" : ""}"
                aria-labelledby="heading_${subtest.subtest_code}"
                data-bs-parent="#subtestAccordion"
              >
                <div class="accordion-body">
                  ${subtestQuestions.map(q => `
                    <div class="border rounded p-3 mb-3">
                      <p><strong>${qNo++}. ${q.text}</strong></p>

                      ${q.options.map(o => `
                        <div class="form-check">
                          <input
                            class="form-check-input"
                            type="radio"
                            name="q_${q.question_id}"
                            value="${o.score}"
                          />
                          <label class="form-check-label">
                            ${o.label}
                          </label>
                        </div>
                      `).join("")}
                    </div>
                  `).join("")}
                </div>
              </div>
            </div>
          `;
        });
      }
    </script>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      is:inline
    ></script>

  </body>
</html>
