---
import BaseLayout from "../../layouts/BaseLayout.astro";
export const prerender = false;
---

<BaseLayout>
  <Fragment slot="head">
    <title>Psychometric Assessment | Success Steps</title>
    <meta
      name="description"
      content="Secure psychometric assessment"
    />
  </Fragment>

  <section class="container py-5 mt-5">
    <h2 class="mb-3">Psychometric Assessment</h2>
    <p class="text-muted mb-4">
      Please complete all questions carefully. Do not refresh the page.
    </p>

    <button id="startBtn" class="btn btn-primary mb-3">
      Start Assessment
    </button>

    <!-- Test selector (shown only if multiple tests) -->
    <div id="testSelector" class="mb-4 d-none">
      <label class="form-label">Select Test</label>
      <select id="testDropdown" class="form-select"></select>
    </div>

    <div id="questionsContainer"></div>

    <button
      id="submitBtn"
      class="btn btn-success mt-4 d-none"
    >
      Submit Assessment
    </button>
  </section>

  <script is:inline>
    /* ---------------------------------------------------------
       0. Session Guard
    --------------------------------------------------------- */
    const token = sessionStorage.getItem("assessmentToken");
    if (!token) {
      window.location.replace("/register");
    }

    /* ---------------------------------------------------------
       1. DOM References
    --------------------------------------------------------- */
    const startBtn = document.getElementById("startBtn");
    const testSelector = document.getElementById("testSelector");
    const testDropdown = document.getElementById("testDropdown");
    const questionsContainer = document.getElementById("questionsContainer");
    const submitBtn = document.getElementById("submitBtn");

    /* ---------------------------------------------------------
       2. Local State (Model B)
    --------------------------------------------------------- */
    let bundle = null;           // Entire test package (fetched once)
    let activeTest = null;       // Currently selected test
    let answers = {};            // { question_id: selected_score }

    /* ---------------------------------------------------------
       3. API Helper
    --------------------------------------------------------- */
    async function apiFetch(url, options = {}) {
      return fetch(url, {
        ...options,
        headers: {
          ...(options.headers || {}),
          "x-assessment-token": token
        }
      });
    }

    /* ---------------------------------------------------------
       4. Start Assessment → Fetch EVERYTHING once
    --------------------------------------------------------- */
    startBtn.addEventListener("click", async () => {
      startBtn.disabled = true;
      startBtn.textContent = "Loading…";

      const res = await apiFetch("/api/psychotest-bundle");
      testpackage = await res.json();

      // 🔑 Normalize GAS response
      bundle = {
        tests: testpackage.payload || []
      };
      console.log(bundle);
      if (!bundle.tests || bundle.tests.length === 0) {
        questionsContainer.innerHTML =
          "<p class='text-danger'>No tests assigned.</p>";
        return;
      }

      initialiseUI();
    });

    /* ---------------------------------------------------------
       5. Initialise UI from Cached Bundle
    --------------------------------------------------------- */
    function initialiseUI() {
      startBtn.classList.add("d-none");

      if (bundle.tests.length === 1) {
        // Only one test → render directly
        activeTest = bundle.tests[0];
        renderTest(activeTest);
      } else {
        // Multiple tests → dropdown
        testSelector.classList.remove("d-none");
        testDropdown.innerHTML =
          `<option value="">-- Select Test --</option>`;

        bundle.tests.forEach(t => {
          const opt = document.createElement("option");
          opt.value = t.test_id;
          opt.textContent = t.test_name;
          testDropdown.appendChild(opt);
        });
      }
    }

    /* ---------------------------------------------------------
       6. Handle Test Selection
    --------------------------------------------------------- */
    testDropdown?.addEventListener("change", e => {
      const testId = e.target.value;
      activeTest = bundle.tests.find(t => t.test_id === testId);
      if (activeTest) renderTest(activeTest);
    });

    /* ---------------------------------------------------------
       7. Render Test (Questions already shuffled by GAS)
    --------------------------------------------------------- */
    function renderTest(test) {
      questionsContainer.innerHTML = "";
      submitBtn.classList.remove("d-none");

      let qNo = 1;

      Object.values(test.subtests).forEach(sub => {
        const subQuestions = test.questions.filter(
          q => q.subtest_code === sub.subtest_code
        );

        const block = document.createElement("div");
        block.className = "mb-4";

        block.innerHTML = `
          <h5 class="mb-3">${sub.subtest_name}</h5>
          ${subQuestions.map(q => `
            <div class="border rounded p-3 mb-3">
              <p><strong>${qNo++}. ${q.text}</strong></p>
              ${q.options.map(o => `
                <div class="form-check">
                  <input
                    class="form-check-input"
                    type="radio"
                    name="q_${q.question_id}"
                    value="${o.score}"
                    ${answers[q.question_id] == o.score ? "checked" : ""}
                  />
                  <label class="form-check-label">${o.label}</label>
                </div>
              `).join("")}
            </div>
          `).join("")}
        `;

        questionsContainer.appendChild(block);
      });

      bindAnswerEvents();
    }

    /* ---------------------------------------------------------
       8. Capture Answers Locally
    --------------------------------------------------------- */
    function bindAnswerEvents() {
      document
        .querySelectorAll("input[type=radio]")
        .forEach(input => {
          input.addEventListener("change", e => {
            const qid = e.target.name.replace("q_", "");
            answers[qid] = Number(e.target.value);
          });
        });
    }

    /* ---------------------------------------------------------
       9. Submit (ONE API CALL)
    --------------------------------------------------------- */
    submitBtn.addEventListener("click", async () => {
      submitBtn.disabled = true;
      submitBtn.textContent = "Submitting…";

      const payload = {
        test_id: activeTest.test_id, 
        answers
      };

      const res = await apiFetch("/api/psychotest-submit", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      });

      const result = await res.json();
    
      if (result.success && res.ok) {
        console.log("Answer Submitted.")
        /* sessionStorage.removeItem("assessmentSession");
        sessionStorage.removeItem("assessmentToken");
        window.location.replace("/assessment/thankyou");  */
      } else {
        alert("Submission failed. Please contact support.");
        submitBtn.disabled = false;
        submitBtn.textContent = "Submit Assessment";
      }
    });
  </script>
</BaseLayout>
