                <li class="mb-1"><i class="bi bi-check-circle-fill text-success me-1"></i>Academic & Wellness (B)</li>
                <li class="mb-1"><i class="bi bi-check-circle-fill text-success me-1"></i>Leadership (C)</li>
                <li class="mb-1"><i class="bi bi-check-circle-fill text-success me-1"></i>Emotional Intelligence (D)</li>
                <li class="mb-1"><i class="bi bi-check-circle-fill text-success me-1"></i>Performance (E)</li>
              </ul>
              <a href="/register?userType=Middle+School" class="btn btn-primary btn-lg w-100">
                Buy Now
              </a>
            </div>
          </div>
        </div>

        <!-- High School Package -->
        <div class="col-lg-3 col-md-6">
          <div class="card h-100 shadow-lg border-0 hover-lift">
            <div class="card-body text-center p-4">
              <div class="bg-warning rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width:90px;height:90px;">
                <div class="text-white fw-bold lh-sm">14–17<br><small>Years</small></div>
              </div>
              <h4 class="card-title fw-bold mb-3">High School</h4>
              <p class="text-muted mb-3 small">Groups A–E · 12 tests</p>
              <div class="h3 fw-bold text-warning mb-3">₹7,500</div>
              <ul class="list-unstyled mb-3 text-start small">
