        </div>

        <!-- College Package -->
        <div class="col-lg-3 col-md-6">
          <div class="card h-100 shadow-lg border-0 hover-lift">
            <div class="card-body text-center p-4">
              <div class="bg-info rounded-circle mx-auto mb-3 p-3 d-inline-block" style="width: 90px; height: 90px; font-size: 0.75rem;">
                <div class="text-white fw-bold">18-22<br>Years</div>
              </div>
              <h4 class="card-title fw-bold mb-3">College</h4>
              <p class="text-muted mb-3 small">15 comprehensive tests</p>
