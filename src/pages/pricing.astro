      <div class="row g-4 justify-content-center">
        
        <!-- Middle School Package -->
        <div class="col-lg-3 col-md-6">
          <div class="card h-100 shadow-lg border-0 hover-lift">
            <div class="card-body text-center p-4">
              <div class="bg-primary rounded-circle mx-auto mb-3 p-3 d-inline-block" style="width: 90px; height: 90px; font-size: 0.75rem;">
                <div class="text-white fw-bold">11-14<br>Years</div>
              </div>
              <h4 class="card-title fw-bold mb-3">Middle School</h4>
              <p class="text-muted mb-3 small">6 foundational tests</p>
              <div class="h3 fw-bold text-primary mb-3">₹5,000</div>
              <ul class="list-unstyled mb-3 text-start small">
                <li class="mb-1"><i class="bi bi-check-circle-fill text-success me-1 fs-6"></i> Learning Style</li>
                <li class="mb-1"><i class="bi bi-check-circle-fill text-success me-1 fs-6"></i> Multiple Intelligence</li>
                <li class="mb-1"><i class="bi bi-check-circle-fill text-success me-1 fs-6"></i> Study Skills</li>
                <li class="mb-1"><i class="bi bi-check-circle-fill text-success me-1 fs-6"></i> Personality (Basic)</li>
              </ul>
              <a href="#" class="btn btn-primary btn-lg w-100" data-package="middleschool">
                Buy Now
              </a>
            </div>
          </div>
        </div>

        <!-- High School Package -->
        <div class="col-lg-3 col-md-6">
          <div class="card h-100 shadow-lg border-0 hover-lift">
            <div class="card-body text-center p-4">
              <div class="bg-warning rounded-circle mx-auto mb-3 p-3 d-inline-block" style="width: 90px; height: 90px; font-size: 0.75rem;">
                <div class="text-white fw-bold">14-17<br>Years</div>
              </div>
              <h4 class="card-title fw-bold mb-3">High School</h4>
              <p class="text-muted mb-3 small">12 essential tests</p>
              <div class="h3 fw-bold text-warning mb-3">₹7,500</div>
              <ul class="list-unstyled mb-3 text-start small">
                <li class="mb-1"><i class="bi bi-check-circle-fill text-success me-1 fs-6"></i> Career Interest</li>
                <li class="mb-1"><i class="bi bi-check-circle-fill text-success me-1 fs-6"></i> Personality (MBTI)</li>
                <li class="mb-1"><i class="bi bi-check-circle-fill text-success me-1 fs-6"></i> Academic Aptitude</li>
                <li class="mb-1"><i class="bi bi-check-circle-fill text-success me-1 fs-6"></i> Emotional Intelligence</li>
              </ul>
              <a href="#" class="btn btn-warning btn-lg w-100" data-package="highschool">
