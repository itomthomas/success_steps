<script>
  // Custom Package Builder Logic
  document.addEventListener('DOMContentLoaded', function() {
    const checkboxes = document.querySelectorAll('.test-checkbox');
    const totalPriceEl = document.getElementById('totalPrice');
    const selectedCountEl = document.getElementById('selectedCount');
    const purchaseBtn = document.getElementById('customPurchaseBtn');
    
    let total = 0;
    let count = 0;
    
    checkboxes.forEach(checkbox => {
      checkbox.addEventListener('change', function() {
        const price = parseInt(this.value);
        
        if (this.checked) {
          total += price;
          count++;
        } else {
          total -= price;
          count--;
        }
        
        updateUI();
      });
    });
    
    function updateUI() {
      if (!totalPriceEl || !selectedCountEl || !purchaseBtn) return;
      selectedCountEl.textContent = count;
      totalPriceEl.textContent = `₹${total.toLocaleString()}`;
      
      const isValid = count >= 5 && count <= 17;
      purchaseBtn.disabled = !isValid;
      purchaseBtn.classList.toggle('disabled', !isValid);
    }
    
    // Package purchase buttons
    document.querySelectorAll('[data-package]').forEach(btn => {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        const pkg = this.dataset.package;
        alert(`Redirecting to purchase ${pkg} package...`);
        // Integrate with your payment flow
      });
    });

    // Coaching audience tabs
    const tabContainer = document.getElementById('coachingTabs');
    if (tabContainer) {
      const tabs = tabContainer.querySelectorAll('.nav-link');
      const panels = document.querySelectorAll('[data-group-panel]');
      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          const group = tab.getAttribute('data-group');
          tabs.forEach(t => t.classList.remove('active'));
          tab.classList.add('active');
          panels.forEach(panel => {
            panel.classList.toggle('d-none', panel.getAttribute('data-group-panel') !== group);
          });
        });
      });
    }
  });
</script>
