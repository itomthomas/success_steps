                <div class="text-white fw-bold lh-sm">11–14<br><small>Years</small></div>
              </div>
              <h4 class="card-title fw-bold mb-3">Middle School</h4>
              <p class="text-muted mb-3 small">Groups A–E · 12 tests</p>
              <div class="h3 fw-bold text-primary mb-3">₹6,800</div>
              <ul class="list-unstyled mb-3 text-start small">
