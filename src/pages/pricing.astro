---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Pricing | SuccessSteps">

  <!-- MAIN HERO -->
  <section class="bg-gradient-primary text-white py-5 mb-5" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
    <div class="container py-2 mt-5 text-center">
      <h1 class="display-4 fw-bold mb-3">SuccessSteps Services</h1>
      <p class="lead mb-4">Certification courses • 1‑to‑1 coaching • Psychometric tests • Corporate training</p>
      <div class="d-flex justify-content-center flex-wrap gap-2">
        <a href="#certifications" class="btn btn-light btn-lg px-4 py-2">🎓 Certification Courses</a>
        <a href="#combo-program" class="btn btn-outline-light btn-lg px-4 py-2">⭐ Best‑Selling Combo</a>
        <a href="#coaching" class="btn btn-outline-light btn-lg px-4 py-2">🧠 Coaching & Therapy</a>
        <a href="#psychometric-tests" class="btn btn-outline-light btn-lg px-4 py-2">📊 Psychometric Tests</a>
      </div>
    </div>
  </section>

  <!-- CERTIFICATION COURSES -->
  <section id="certifications" class="py-2 bg-light">
    <div class="container">
      <h2 class="text-center mb-4">Certification Courses – NLP, Coaching & Therapy</h2>
      <p class="text-center text-muted mb-5">
        Structured tracks from foundational learning to advanced professional certifications.
      </p>

      <!-- NLP Track -->
      <div class="mb-4">
        <button class="btn btn-link text-decoration-none w-100 text-start d-flex justify-content-between align-items-center" type="button" data-bs-toggle="collapse" data-bs-target="#nlpTrack">
          <span class="fw-bold">NLP Track</span>
          <span class="small text-muted">Basic → Diploma → Advanced Diploma → Practitioner → Master Practitioner</span>
        </button>
        <div id="nlpTrack" class="collapse show">
          <div class="card shadow-sm">
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table mb-0">
                  <thead class="table-light">
                    <tr><th>Certification Course</th><th>Duration</th><th>Fees (₹)</th></tr>
                  </thead>
                  <tbody>
                    <tr><td>NLP Basic</td><td>10 hours</td><td>10,000</td></tr>
                    <tr><td>NLP Diploma</td><td>10 hours</td><td>10,000</td></tr>
                    <tr><td>NLP Advanced Diploma</td><td>10 hours</td><td>10,000</td></tr>
                    <tr><td>NLP Practitioner</td><td>40 hours</td><td>30,000</td></tr>
                    <tr><td>NLP Master Practitioner</td><td>50 hours</td><td>40,000</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Coaching Track -->
      <div class="mb-4">
        <button class="btn btn-link text-decoration-none w-100 text-start d-flex justify-content-between align-items-center" type="button" data-bs-toggle="collapse" data-bs-target="#coachingTrack">
          <span class="fw-bold">Coaching Track</span>
          <span class="small text-muted">Life, EI, leadership & performance coaching</span>
        </button>
        <div id="coachingTrack" class="collapse">
          <div class="card shadow-sm">
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table mb-0">
                  <thead class="table-light">
                    <tr><th>Certification Course</th><th>Duration</th><th>Fees (₹)</th></tr>
                  </thead>
                  <tbody>
                    <tr><td>Certified Life Coach</td><td>15 hours</td><td>20,000</td></tr>
                    <tr><td>Emotional Intelligence Coach</td><td>20 hours</td><td>20,000</td></tr>
                    <tr><td>Peak Performance Coach</td><td>10 hours</td><td>10,000</td></tr>
                    <tr><td>Accelerated Learning Coach</td><td>10 hours</td><td>10,000</td></tr>
                    <tr><td>Executive Leadership Coach</td><td>10 hours</td><td>12,000</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Therapy & Counselling Track -->
      <div class="mb-4">
        <button class="btn btn-link text-decoration-none w-100 text-start d-flex justify-content-between align-items-center" type="button" data-bs-toggle="collapse" data-bs-target="#therapyTrack">
          <span class="fw-bold">Therapy & Counselling Track</span>
          <span class="small text-muted">Counselling models & therapeutic approaches</span>
        </button>
        <div id="therapyTrack" class="collapse">
          <div class="card shadow-sm">
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table mb-0">
                  <thead class="table-light">
                    <tr><th>Certification Course</th><th>Duration</th><th>Fees (₹)</th></tr>
                  </thead>
                  <tbody>
                    <tr><td>Foundations of Behaviour & Basic Counselling Skills</td><td>10 hours</td><td>10,000</td></tr>
                    <tr><td>CBT – Cognitive Behaviour Therapy</td><td>10 hours</td><td>10,000</td></tr>
                    <tr><td>REBT – Rational Emotive Behaviour Therapy</td><td>10 hours</td><td>10,000</td></tr>
                    <tr><td>Gestalt Therapy</td><td>10 hours</td><td>10,000</td></tr>
                    <tr><td>Transpersonal Hypnosis</td><td>10 hours</td><td>22,000</td></tr>
                    <tr><td>Access Bars Therapy</td><td>10 hours</td><td>10,000</td></tr>
                    <tr><td>Transactional Analysis</td><td>10 hours</td><td>10,000</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Neuroscience & EI Track -->
      <div class="mb-4">
        <button class="btn btn-link text-decoration-none w-100 text-start d-flex justify-content-between align-items-center" type="button" data-bs-toggle="collapse" data-bs-target="#neuroTrack">
          <span class="fw-bold">Neuroscience & Emotional Intelligence Track</span>
          <span class="small text-muted">Brain‑based and EI‑focused development</span>
        </button>
        <div id="neuroTrack" class="collapse">
          <div class="card shadow-sm">
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table mb-0">
                  <thead class="table-light">
                    <tr><th>Certification Course</th><th>Duration</th><th>Fees (₹)</th></tr>
                  </thead>
                  <tbody>
                    <tr><td>Applied Neuroscience</td><td>10 hours</td><td>12,000</td></tr>
                    <tr><td>EI Master Coach</td><td>20 hours</td><td>20,000</td></tr>
                    <tr><td>Energy Healing Psychology & Practices</td><td>10 hours</td><td>10,000</td></tr>
                    <tr><td>EFT – Emotional Freedom Technique</td><td>10 hours</td><td>10,000</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Career & Psychometric Track -->
      <div class="mb-4">
        <button class="btn btn-link text-decoration-none w-100 text-start d-flex justify-content-between align-items-center" type="button" data-bs-toggle="collapse" data-bs-target="#careerTrack">
          <span class="fw-bold">Career & Psychometric Track</span>
          <span class="small text-muted">Career counselling and psychometric testing</span>
        </button>
        <div id="careerTrack" class="collapse">
          <div class="card shadow-sm">
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table mb-0">
                  <thead class="table-light">
                    <tr><th>Certification Course</th><th>Duration</th><th>Fees (₹)</th></tr>
                  </thead>
                  <tbody>
                    <tr><td>Career Counselling, Guidance, Psychometric Test & Analysis</td><td>20 hours</td><td>25,000</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- BEST-SELLING COMBO -->
  <section id="combo-program" class="py-5">
    <div class="container">
      <div class="card shadow-lg border-0 popular">
        <div class="row g-0 align-items-stretch">
          <div class="col-lg-8 p-4 p-lg-5">
            <span class="badge bg-danger mb-3">Best‑Selling Professional Combo</span>
            <h2 class="fw-bold mb-3">NLP Practitioner + Emotional Intelligence + Applied Neuroscience<br/>Life Coaching & Leadership Coaching</h2>
            <p class="text-muted mb-3">
              A comprehensive combo for personal transformation, practical coaching skills, and leadership impact.
            </p>
            <div class="row">
              <div class="col-md-6 mb-3">
                <h5 class="fw-bold mb-2">What You'll Learn</h5>
                <ul class="small mb-0">
                  <li>Master thoughts, emotions, and behaviours with NLP</li>
                  <li>Build emotional intelligence for work and life</li>
                  <li>Use brain‑based tools for focus and performance</li>
                </ul>
              </div>
              <div class="col-md-6 mb-3">
                <h5 class="fw-bold mb-2">Who It's For</h5>
                <ul class="small mb-0">
                  <li>Coaches, counsellors, trainers, and therapists</li>
                  <li>Leaders, managers, HR & L&D professionals</li>
                  <li>Anyone serious about growth and impact</li>
                </ul>
              </div>
            </div>
          </div>
          <div class="col-lg-4 p-4 p-lg-5 bg-light border-start">
            <p class="mb-1 text-muted">Program Fee</p>
            <div class="d-flex align-items-baseline gap-2 mb-1">
              <span class="text-muted text-decoration-line-through">₹85,000</span>
              <span class="h3 fw-bold text-success mb-0">₹65,000</span>
            </div>
            <p class="small text-success mb-2">You save ₹20,000</p>
            <p class="mb-3"><strong>Duration:</strong> 60 hours (approx. 2.5 months)</p>
            <button class="btn btn-success w-100 mb-2">Enroll in Combo</button>
            <button class="btn btn-outline-secondary w-100 mb-3">Download Detailed Curriculum</button>
            <ul class="small text-muted mb-0">
              <li>Multiple certifications in one integrated pathway</li>
              <li>Rooted in psychology, neuroscience, NLP & EI</li>
              <li>Suitable for both personal and professional growth</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- COACHING & THERAPY -->
  <section id="coaching" class="py-3 bg-dark">
    <div class="container">
      <h2 class="text-center text-white mb-4">Counselling, Therapy & Life Coaching</h2>
      <p class="text-center text-white mb-5">
        One‑to‑one sessions focused on deep emotional work, mindset change, and practical strategies for lasting results.
      </p>

      <!-- Single Session -->
      <div class="row justify-content-center mb-4">
        <div class="col-md-6">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <h4 class="fw-bold mb-2">Individual Session</h4>
              <p class="text-muted mb-3">60‑minute personalised session (online or in‑person)</p>
              <div class="d-flex align-items-baseline gap-2 mb-2">
                <span class="h3 fw-bold">₹3,500</span>
                <span class="small text-muted">per session</span>
              </div>
              <p class="small text-muted mb-2">Additional hour: ₹1,000</p>
              <button class="btn btn-primary w-100">Book a Single Session</button>
            </div>
          </div>
        </div>
      </div>

      <!-- Packages -->
      <div class="row g-4">
        <div class="col-md-4">
          <div class="card h-100 shadow-sm">
            <div class="card-body d-flex flex-column">
              <h5 class="fw-bold mb-1">5‑Session Package</h5>
              <p class="small text-muted mb-3">Ideal for short‑term clarity or a specific issue.</p>
              <p class="mb-1"><strong>Total:</strong> ₹16,000</p>
              <p class="mb-3"><strong>Per session:</strong> ₹3,200</p>
              <p class="small text-muted mb-4">Great for stress, decision‑making, or confidence boosts.</p>
              <button class="btn btn-outline-primary mt-auto w-100">Get 5‑Session Package</button>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card h-100 shadow-sm popular">
            <div class="card-body d-flex flex-column">
              <span class="badge bg-success mb-2">Most Popular</span>
              <h5 class="fw-bold mb-1">10‑Session Package</h5>
              <p class="small text-muted mb-3">Best for emotional healing and mindset change.</p>
              <p class="mb-1"><strong>Total:</strong> ₹30,000</p>
              <p class="mb-3"><strong>Per session:</strong> ₹3,000</p>
              <p class="small text-muted mb-4">Allows deeper exploration and consistent progress.</p>
              <button class="btn btn-primary mt-auto w-100">Get 10‑Session Package</button>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card h-100 shadow-sm">
            <div class="card-body d-flex flex-column">
              <h5 class="fw-bold mb-1">15‑Session Package</h5>
              <p class="small text-muted mb-3">For long‑term transformation and complex goals.</p>
              <p class="mb-1"><strong>Total:</strong> ₹42,000</p>
              <p class="mb-3"><strong>Per session:</strong> ₹2,800</p>
              <p class="small text-muted mb-4">Supports deep behavioural change over time.</p>
              <button class="btn btn-outline-primary mt-auto w-100">Get 15‑Session Package</button>
            </div>
          </div>
        </div>
      </div>

      <!-- Audience Tabs -->
      <div class="mt-5">
        <ul class="nav nav-pills justify-content-center mb-3" id="coachingTabs">
          <li class="nav-item"><button class="nav-link active" data-group="adults" type="button">Adults</button></li>
          <li class="nav-item"><button class="nav-link" data-group="children" type="button">Children</button></li>
          <li class="nav-item"><button class="nav-link" data-group="professionals" type="button">Professionals</button></li>
        </ul>
        <div class="card shadow-sm">
          <div class="card-body">
            <div data-group-panel="adults">
              <h5 class="fw-bold mb-2">Adults – Individual Sessions</h5>
              <ul class="small mb-0">
                <li>Stress and anxiety management</li>
                <li>Emotional healing and relationship challenges</li>
                <li>Confidence, clarity, and self‑belief</li>
                <li>Success mindset and goal alignment</li>
                <li>Leadership presence and decision‑making</li>
              </ul>
            </div>
            <div data-group-panel="children" class="d-none">
              <h5 class="fw-bold mb-2">Children – Individual Sessions</h5>
              <ul class="small mb-0">
                <li>Focus and concentration improvement</li>
                <li>Smart study methods and learning confidence</li>
                <li>Peak performance for exams and competitions</li>
                <li>Accelerated learning and memory techniques</li>
                <li>Emotional regulation and motivation</li>
              </ul>
            </div>
            <div data-group-panel="professionals" class="d-none">
              <h5 class="fw-bold mb-2">Professionals – Individual Sessions</h5>
              <ul class="small mb-0">
                <li>Emotional intelligence at work</li>
                <li>Leadership development</li>
                <li>High‑performance and success mindset</li>
                <li>Sales confidence and influence skills</li>
              </ul>
            </div>
          </div>
        </div>
        <p class="small text-muted mt-2 text-center mb-0">
          All sessions are one‑to‑one, 60 minutes each, and personalised to your goals.
        </p>
      </div>
    </div>
  </section>

  <!-- TRAINING & SEMINARS -->
  <section id="training" class="py-5">
    <div class="container">
      <h2 class="text-center mb-4">Training & Seminars</h2>
      <p class="text-center text-muted mb-4">
        High‑impact programs for teachers, students, and corporate teams.
      </p>
      <p class="text-center small text-muted mb-5">
        All training programs are 4–6 hours per day. Travel & stay extra outside Mumbai.
      </p>
      <div class="row g-4">
        <div class="col-md-4">
          <div class="card h-100 shadow-sm">
            <div class="card-body d-flex flex-column">
              <h5 class="fw-bold mb-2">Teachers' Training</h5>
              <p class="small text-muted mb-3">Psychology‑driven programs for educators.</p>
              <p class="mb-3"><strong>Fee:</strong> ₹25,000 per day</p>
              <ul class="small mb-4">
                <li>Student psychology & emotional intelligence</li>
                <li>Stress management for teachers</li>
                <li>Effective communication & classroom engagement</li>
              </ul>
              <button class="btn btn-outline-primary mt-auto w-100">Request Proposal</button>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card h-100 shadow-sm">
            <div class="card-body d-flex flex-column">
              <h5 class="fw-bold mb-2">Students' Seminars</h5>
              <p class="small text-muted mb-3">Motivational and skills‑based sessions.</p>
              <p class="mb-3"><strong>Fee:</strong> ₹25,000 per day</p>
              <ul class="small mb-4">
                <li>Motivation, focus, and exam readiness</li>
                <li>Memory skills and smart study methods</li>
                <li>Emotional resilience and confidence building</li>
              </ul>
              <button class="btn btn-outline-primary mt-auto w-100">Request Proposal</button>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card h-100 shadow-sm popular">
            <div class="card-body d-flex flex-column">
              <span class="badge bg-success mb-2">For Organizations</span>
              <h5 class="fw-bold mb-2">Corporate Training</h5>
              <p class="small text-muted mb-3">Leadership and performance for teams.</p>
              <p class="mb-3"><strong>Fee:</strong> ₹35,000 per day</p>
              <ul class="small mb-4">
                <li>Emotional intelligence and leadership mindset</li>
                <li>Performance under pressure</li>
                <li>Communication and team effectiveness</li>
              </ul>
              <button class="btn btn-primary mt-auto w-100">Request Proposal</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PSYCHOMETRIC TESTS HERO -->
  <section id="psychometric-tests" class="text-white py-5 mb-5" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
    <div class="container text-center">
      <h2 class="display-6 fw-bold mb-3">Psychometric Tests</h2>
      <p class="lead mb-4">Scientifically designed assessments across 5 key domains</p>
      <a href="#custom-builder" class="btn btn-light btn-lg px-5 py-3">🎯 Build Custom Package</a>
    </div>
  </section>

  <!-- Age-based Psychometric Packages -->
  <section class="py-5 mb-5">
    <div class="container">
      <div class="row g-4 justify-content-center">

