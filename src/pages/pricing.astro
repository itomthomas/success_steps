<script>
document.addEventListener('DOMContentLoaded', function () {

  // ── 1. Coaching audience tabs ─────────────────────────────────────
  const coachingTabContainer = document.getElementById('coachingTabs');
  if (coachingTabContainer) {
    const coachingTabs   = coachingTabContainer.querySelectorAll('.nav-link');
    const coachingPanels = document.querySelectorAll('[data-group-panel]');
    coachingTabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        const group = tab.getAttribute('data-group');
        coachingTabs.forEach(function(t) { t.classList.remove('active'); });
        tab.classList.add('active');
        coachingPanels.forEach(function(panel) {
          panel.classList.toggle('d-none', panel.getAttribute('data-group-panel') !== group);
        });
      });
    });
  }

  // ── 2. Custom Package Builder ─────────────────────────────────────
  const PACKAGE_DATA = {
    "Middle School": [
      {
        id: "ms_a", label: "Group A — Core Assessments",
        comboPrice: 3550,
        tests: [
          { name: "Aptitude Test" },
          { name: "Multiple Intelligence Test" },
          { name: "Personality Test" },
        ]
      },
      {
        id: "ms_b", label: "Group B — Academic & Wellness",
        comboPrice: 850,
        tests: [
          { name: "Academic Performance Diagnostic" },
          { name: "Student's Wellness Dimensions" },
          { name: "Learning Style Test" },
        ]
      },
      {
        id: "ms_c", label: "Group C — Leadership",
        comboPrice: 800,
        tests: [
          { name: "The Leadership Competency Matrix" },
          { name: "The Leadership Styles" },
        ]
      },
      {
        id: "ms_d", label: "Group D — Emotional Intelligence",
        comboPrice: 850,
        tests: [
          { name: "Emotional Intelligence" },
          { name: "The Right and Left Brain Dominance" },
        ]
      },
      {
        id: "ms_e", label: "Group E — Performance & Wellbeing",
        comboPrice: 800,
        tests: [
          { name: "Understanding Pre-Competition State" },
          { name: "The Internet Addiction Test" },
        ]
      },
    ],
    "High School": [
      {
        id: "hs_a", label: "Group A — Core Assessments",
        comboPrice: 4200,
        tests: [
          { name: "Aptitude Test" },
          { name: "Multiple Intelligence Test" },
          { name: "Personality Test" },
        ]
      },
      {
        id: "hs_b", label: "Group B — Academic & Wellness",
        comboPrice: 850,
        tests: [
          { name: "Academic Performance Diagnostic" },
          { name: "Student's Wellness Dimensions" },
          { name: "Learning Style Test" },
        ]
      },
      {
        id: "hs_c", label: "Group C — Leadership",
        comboPrice: 800,
        tests: [
          { name: "The Leadership Competency Matrix" },
          { name: "The Leadership Styles" },
        ]
      },
      {
        id: "hs_d", label: "Group D — Emotional Intelligence",
        comboPrice: 850,
        tests: [
          { name: "Emotional Intelligence" },
          { name: "The Right and Left Brain Dominance" },
        ]
      },
      {
        id: "hs_e", label: "Group E — Performance & Wellbeing",
        comboPrice: 800,
        tests: [
          { name: "Understanding Pre-Competition State" },
          { name: "The Internet Addiction Test" },
        ]
      },
    ],
    "College Student": [
      {
        id: "co_a", label: "Group A — Core Assessments",
        comboPrice: 4200,
        tests: [
          { name: "Aptitude Test" },
          { name: "Multiple Intelligence Test" },
          { name: "Personality Test" },
        ]
      },
      {
        id: "co_b", label: "Group B — Academic & Wellness",
        comboPrice: 850,
        tests: [
          { name: "Academic Performance Diagnostic" },
          { name: "Student's Wellness Dimensions" },
          { name: "Learning Style Test" },
        ]
      },
      {
        id: "co_c", label: "Group C — Leadership",
        comboPrice: 800,
        tests: [
          { name: "The Leadership Competency Matrix" },
          { name: "The Leadership Styles" },
        ]
      },
      {
        id: "co_d", label: "Group D — Emotional Intelligence",
        comboPrice: 850,
        tests: [
          { name: "Emotional Intelligence" },
          { name: "The Right and Left Brain Dominance" },
        ]
      },
      {
        id: "co_e", label: "Group E — Performance & Wellbeing",
        comboPrice: 800,
        tests: [
          { name: "Understanding Pre-Competition State" },
          { name: "The Internet Addiction Test" },
        ]
      },
      {
        id: "co_addon", label: "College Add-on — Professional Skills",
        comboPrice: 500,
        isAddon: true,
        tests: [
          { name: "Professional Skills Set Assessment" },
        ]
      },
    ],
    "Professional": [
      {
        id: "pr_a", label: "Group A — Core Assessments",
        comboPrice: 2550,
        tests: [
          { name: "Multiple Intelligence Test" },
          { name: "Personality Test" },
        ]
      },
      {
        id: "pr_b", label: "Group B — Wellness & Learning",
        comboPrice: 500,
        tests: [
          { name: "Wellness Dimensions" },
          { name: "Learning Style Test" },
        ]
      },
      {
        id: "pr_c", label: "Group C — Leadership",
        comboPrice: 800,
        tests: [
          { name: "The Leadership Competency Matrix" },
          { name: "The Leadership Styles" },
        ]
      },
      {
        id: "pr_d", label: "Group D — Emotional Intelligence",
        comboPrice: 850,
        tests: [
          { name: "Emotional Intelligence" },
          { name: "The Right and Left Brain Dominance" },
        ]
      },
      {
        id: "pr_e", label: "Group E — Performance & Wellbeing",
        comboPrice: 800,
        tests: [
          { name: "Understanding Pre-Competition State" },
          { name: "The Internet Addiction Test" },
        ]
      },
      {
        id: "pr_f", label: "Group F — Professional Suitability",
        comboPrice: 2450,
        tests: [
          { name: "Professional Skills Set Assessment" },
          { name: "Entrepreneurship Suitability Assessment" },
          { name: "Professional Suitability Assessment" },
          { name: "Integrity Assessment" },
        ]
      },
      {
        id: "pr_g", label: "Group G — Life & Work Balance",
        comboPrice: 1000,
        isOptional: true,
        tests: [
          { name: "Parenting Style" },
          { name: "Work Life Balance" },
        ]
      },
    ],
  };


  // ── State ────────────────────────────────────────────────────────
  var activeCategory = "Middle School";
  var selected = new Map(); // groupId → { label, comboPrice, tests }

  // ── All DOM refs looked up inside each function — never at top scope ──
  // This avoids Astro bundler hoisting issues where getElementById returns null

  function renderGroups(category) {
    var container = document.getElementById('groupsContainer');
    if (!container) { console.error('[Builder] #groupsContainer not found'); return; }

    var groups = PACKAGE_DATA[category] || [];
    container.innerHTML = '';

    groups.forEach(function(group) {
      var isSelected = selected.has(group.id);

      var wrapper = document.createElement('div');
      wrapper.className = 'mb-3';
      wrapper.innerHTML =
        '<div class="group-card border rounded-3 p-3'
          + (isSelected       ? ' group-card--selected' : '')
          + (group.isOptional ? ' border-dashed' : '')
          + '" data-group-id="' + group.id + '">'
        + '<div class="d-flex align-items-start gap-3">'
        + '<input class="form-check-input group-checkbox flex-shrink-0 mt-1"'
          + ' type="checkbox" id="grp_' + group.id + '"'
          + (isSelected ? ' checked' : '')
          + ' style="width:1.2rem;height:1.2rem;cursor:pointer;" />'
        + '<div class="flex-grow-1">'
        + '<div class="d-flex justify-content-between align-items-start flex-wrap gap-2">'
        + '<label class="fw-semibold mb-0" for="grp_' + group.id + '" style="cursor:pointer;">'
          + group.label.replace(/^Group [A-Z] \u2014 /, '')
          + (group.isOptional ? ' <span class="badge bg-secondary ms-2" style="font-size:0.7rem;">Optional</span>' : '')
          + (group.isAddon    ? ' <span class="badge bg-info ms-2"      style="font-size:0.7rem;">Add-on</span>'   : '')
        + '</label>'
        + '<span class="badge bg-primary fs-6 px-3 py-2">₹' + group.comboPrice.toLocaleString('en-IN') + '</span>'
        + '</div>'
        + '<ul class="mb-0 mt-2 ps-3" style="font-size:0.82rem;color:#6c757d;">'
          + group.tests.map(function(t) { return '<li>' + t.name + '</li>'; }).join('')
        + '</ul>'
        + '</div>'
        + '</div>'
        + '</div>';

      container.appendChild(wrapper);

      var checkbox = wrapper.querySelector('#grp_' + group.id);
      var cardEl   = wrapper.querySelector('.group-card');

      function toggle(forceState) {
        var nowChecked = forceState !== undefined ? forceState : !checkbox.checked;
        checkbox.checked = nowChecked;
        if (nowChecked) {
          selected.set(group.id, {
            label:      group.label,
            comboPrice: group.comboPrice,
            tests:      group.tests
          });
          cardEl.classList.add('group-card--selected');
        } else {
          selected.delete(group.id);
          cardEl.classList.remove('group-card--selected');
        }
        updateSidebar();
      }

      cardEl.addEventListener('click', function(e) {
        if (e.target === checkbox) return; // checkbox fires its own change event
        toggle();
      });
      checkbox.addEventListener('change', function() { toggle(checkbox.checked); });
    });
  }

  function updateSidebar() {
    var count      = selected.size;
    var comboTotal = 0;
    selected.forEach(function(g) { comboTotal += g.comboPrice; });

    // Group count label
    var groupCountLabel = document.getElementById('groupCountLabel');
    if (groupCountLabel) groupCountLabel.textContent = count + ' group' + (count !== 1 ? 's' : '') + ' selected';

    // Selected breakdown list
    var selectedListEl = document.getElementById('selectedList');
    if (selectedListEl) {
      if (count === 0) {
        selectedListEl.innerHTML = '<span class="text-muted fst-italic">No groups selected yet\u2026</span>';
      } else {
        var html = '';
        selected.forEach(function(g) {
          html += '<div class="border-bottom pb-1 mb-1">'
            + '<div class="d-flex justify-content-between fw-semibold" style="font-size:0.82rem;">'
            + '<span>' + g.label + '</span>'
            + '<span class="text-success ms-2 flex-shrink-0">₹' + g.comboPrice.toLocaleString('en-IN') + '</span>'
            + '</div>'
            + '<ul class="mb-0 ps-3" style="font-size:0.75rem;color:#6c757d;">'
            + g.tests.map(function(t) { return '<li>' + t.name + '</li>'; }).join('')
            + '</ul></div>';
        });
        selectedListEl.innerHTML = html;
      }
    }

    // Price fields
    var totalPriceEl = document.getElementById('totalPrice');
    if (totalPriceEl) totalPriceEl.textContent = '₹' + comboTotal.toLocaleString('en-IN');

    // Validation + button
    var validationMsg  = document.getElementById('validationMsg');
    var validationText = document.getElementById('validationText');
    var purchaseBtn    = document.getElementById('customPurchaseBtn');
    if (count === 0) {
      if (validationText) validationText.textContent = 'Select at least one group to continue';
      if (validationMsg)  validationMsg.classList.remove('d-none');
    } else {
      if (validationMsg)  validationMsg.classList.add('d-none');
    }
    if (purchaseBtn) purchaseBtn.disabled = (count === 0);
  }

  // ── Category tab switching (scoped to #categoryTabs) ─────────────
  var categoryTabButtons = document.querySelectorAll('#categoryTabs [data-category]');
  categoryTabButtons.forEach(function(tab) {
    tab.addEventListener('click', function() {
      categoryTabButtons.forEach(function(t) { t.classList.remove('active'); });
      tab.classList.add('active');
      activeCategory = tab.dataset.category;
      var badge = document.getElementById('activeCategoryBadge');
      if (badge) badge.textContent = activeCategory;
      selected.clear();
      updateSidebar();
      renderGroups(activeCategory);
    });
  });

  // ── Clear All ─────────────────────────────────────────────────────
  var clearAllBtn = document.getElementById('clearAllBtn');
  if (clearAllBtn) {
    clearAllBtn.addEventListener('click', function() {
      selected.clear();
      renderGroups(activeCategory);
      updateSidebar();
    });
  }

  // ── Buy Now → /register with compact group IDs ──────────────────
  // e.g. ?userType=Middle+School&groups=ms_a,ms_c
  var purchaseBtnEl = document.getElementById('customPurchaseBtn');
  if (purchaseBtnEl) {
    purchaseBtnEl.addEventListener('click', function() {
      var groupIds = Array.from(selected.keys()); // ['ms_a', 'ms_c', ...]
      var params = new URLSearchParams({
        userType: activeCategory,
        groups:   groupIds.join(',')
      });
      window.location.href = '/register?' + params.toString();
    });
  }

  // ── Boot ─────────────────────────────────────────────────────────
  renderGroups(activeCategory);
  updateSidebar();

}); // end DOMContentLoaded
</script>