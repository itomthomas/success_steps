        <div class="col-lg-3 col-md-12">
          <div class="card h-100 shadow-lg border-0 hover-lift popular position-relative">
            <span class="badge bg-danger position-absolute top-0 start-50 translate-middle-x mt-2 z-3 px-3 py-2">⭐ MOST POPULAR</span>
            <div class="card-body text-center p-4">
              <div class="bg-success rounded-circle mx-auto mb-3 p-3 d-inline-block" style="width: 90px; height: 90px; font-size: 0.75rem;">
                <div class="text-white fw-bold">23+<br>Years</div>
              </div>
              <h4 class="card-title fw-bold mb-3">Professionals</h4>
              <p class="text-muted mb-3 small">17 advanced tests + reports</p>
              <div class="h3 fw-bold text-success mb-3">₹9,500</div>
              <ul class="list-unstyled mb-3 text-start small">
