  <!-- PSYCHOMETRIC TESTS HERO -->
  <section id="psychometric-tests" class="bg-gradient-primary text-white py-5 mb-5" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
    <div class="container text-center">
      <h2 class="display-6 fw-bold mb-3">Psychometric Tests</h2>
      <p class="lead mb-4">93 test sections • 500+ questions across 20 categories</p>
      <a href="#custom-builder" class="btn btn-light btn-lg px-5 py-3">🎯 Build Custom Package</a>
    </div>
  </section>

  <!-- Age-based Psychometric Packages -->
  <section class="py-5 mb-5">
