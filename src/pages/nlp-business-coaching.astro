---
import BaseLayout from '../layouts/BaseLayout.astro';
import CompareBox from '../components/blog/CompareBox.astro';
import PullQuote from '../components/blog/PullQuote.astro';
import ReflectionBox from '../components/blog/ReflectionBox.astro';

const heroTitle = "Transform Leaders. Elevate Teams.";
const tagline = "NLP Business Coaching & Corporate Retreats";
export const prerender = true;  // keeping this page static for blazing fast load and SEO benefits
---

<BaseLayout title="Corporate Coaching & Retreat | SuccessSteps">

  <!-- HERO -->
  <section class="text-white py-5" style="background: linear-gradient(135deg,#1e3c72,#2a5298);">
  <div class="container mt-5">
    <div class="row align-items-center">

      <!-- LEFT TEXT -->
      <div class="col-lg-6 text-center text-lg-start">
        <h1 class="display-4 fw-bold">{heroTitle}</h1>
        <p class="lead mt-3">{tagline}</p>

        <p class="mt-3">
          Two powerful transformation paths — one for individuals, one for teams.
        </p>

        <div class="d-flex flex-wrap gap-2 mt-4 justify-content-center justify-content-lg-start">
          <a href="#coaching" class="btn btn-light">Business Coaching</a>
          <a href="#retreat" class="btn btn-outline-light">Corporate Retreat</a>
        </div>
      </div>

      <!-- RIGHT IMAGE -->
      <div class="col-lg-6 text-center mt-4 mt-lg-0">
        <img 
          src="https://images.unsplash.com/photo-1552664730-d307ca884978"
          class="img-fluid rounded-4 shadow-lg"
          alt="Corporate Leadership"
        />
      </div>

    </div>
  </div>
</section>

  <!-- 🔥 DIFFERENCE SECTION -->
  <section class="py-5 bg-light">
    <div class="container">

      <h2 class="text-center mb-5">Choose Your Transformation Path</h2>

      <CompareBox
        bossLabel="NLP Business Coaching"
        bossQuote="Deep personal transformation, mindset mastery, and long-term growth."
        leaderLabel="Corporate Retreat"
        leaderQuote="High-impact team experience designed to align, energize, and transform organizations."
      />

      <div class="row mt-5">
        <div class="col-md-6">
          <ul>
            <li>✔ 1-on-1 or small group</li>
            <li>✔ Long-term engagement</li>
            <li>✔ Focus on YOU</li>
          </ul>
        </div>
        <div class="col-md-6">
          <ul>
            <li>✔ Team-based immersive program</li>
            <li>✔ Short-term intensive</li>
            <li>✔ Focus on ORGANIZATION</li>
          </ul>
        </div>
      </div>

    </div>
  </section>
 <!--  <section>
  <img 
    src="https://images.unsplash.com/photo-1504384308090-c894fdcc538d"
    class="w-100"
    style="max-height:400px; object-fit:cover;"
    alt="Team Collaboration"
  />
</section> -->

  <!-- 🧠 BUSINESS COACHING -->
  <section id="coaching" class="py-5 bg-white">
    <div class="container">

      <h2 class="text-center mb-4">NLP Business Coaching</h2>

      <PullQuote>
        True business growth begins with transforming how you think, decide, and lead.
      </PullQuote>

      <p class="text-center text-muted mb-5">
        A personalized journey to unlock your full business and leadership potential.
      </p>

      <div class="row align-items-center mb-5">
  <div class="col-md-6">
    <img 
      src="https://images.unsplash.com/photo-1543269865-cbf427effbad"
      class="img-fluid rounded-4 shadow"
      alt="Business Coaching"
    />
  </div>

  <div class="col-md-6">
    <h4 class="fw-bold">Personalized Growth & Strategy</h4>
    <p>
      NLP coaching helps professionals unlock clarity, confidence, and performance through mindset transformation.
    </p>
  </div>
</div>

      <div class="row g-4">

        <div class="col-md-4">
          <div class="card shadow border-0 text-center p-4">
            <i class="bi bi-lightbulb fs-1 text-primary mb-3"></i>
            <h5>Mindset Mastery</h5>
            <p>Break limiting beliefs and develop high-performance thinking.</p>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card shadow border-0 text-center p-4">
            <i class="bi bi-chat-dots fs-1 text-primary mb-3"></i>
            <h5>Communication</h5>
            <p>Influence, persuade, and build powerful relationships.</p>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card shadow border-0 text-center p-4">
            <i class="bi bi-graph-up fs-1 text-primary mb-3"></i>
            <h5>Growth Strategy</h5>
            <p>Make better decisions and accelerate business results.</p>
          </div>
        </div>

      </div>

      <!-- Reflection -->
      <div class="mt-5">
        <ReflectionBox
          title="Is Business Coaching Right For You?"
          questions={[
            "Do I feel stuck despite working hard?",
            "Do I want faster, clearer decision-making?",
            "Am I ready to upgrade my mindset and leadership?"
          ]}
        />
      </div>

    </div>
  </section>

  <!-- 🏢 CORPORATE RETREAT -->
  <section id="retreat" class="py-5 bg-light">
    <div class="container">

      <h2 class="text-center mb-4">Corporate Retreat Program</h2>

      <PullQuote>
        Great organizations are built when leaders and teams grow together.
      </PullQuote>

      <p class="text-center text-muted mb-5">
        A high-energy immersive experience designed to align teams and unlock collective performance.
      </p>
      
      <div class="row align-items-center mb-5">
  <div class="col-md-6 order-md-2">
    <img 
      src="https://images.unsplash.com/photo-1521737604893-d14cc237f11d"
      class="img-fluid rounded-4 shadow"
      alt="Corporate Team Retreat"
    />
  </div>

  <div class="col-md-6 order-md-1">
    <h4 class="fw-bold">Transform Teams Through Experience</h4>
    <p>
      Immersive retreat programs align teams, build trust, and unlock collective performance.
    </p>
  </div>
</div>

      <div class="row g-4">

        <div class="col-md-4">
          <div class="card shadow border-0 text-center p-4">
            <i class="bi bi-bullseye fs-1 text-success mb-3"></i>
            <h5>Vision to Reality</h5>
            <p>Turn strategy into execution with clarity and confidence.</p>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card shadow border-0 text-center p-4">
            <i class="bi bi-people fs-1 text-success mb-3"></i>
            <h5>Team Alignment</h5>
            <p>Create collaboration, trust, and shared purpose.</p>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card shadow border-0 text-center p-4">
            <i class="bi bi-lightning fs-1 text-success mb-3"></i>
            <h5>Performance Boost</h5>
            <p>Drive motivation, accountability, and results.</p>
          </div>
        </div>

      </div>

      <!-- Reflection -->
      <div class="mt-5">
        <ReflectionBox
          title="Is Your Team Ready for a Breakthrough?"
          questions={[
            "Is there a gap between vision and execution?",
            "Does your team lack alignment or motivation?",
            "Do you want stronger leadership across all levels?"
          ]}
        />
      </div>

    </div>
  </section>

  <!-- 🎯 TOPICS -->
  <section class="py-5 bg-white">
    <div class="container">

      <h2 class="text-center mb-5">Key Topics Covered</h2>

      <div class="row g-2">
        {[
          "Leadership","Emotional Intelligence","Communication",
          "Team Building","Decision Making","Innovation",
          "Conflict Resolution","Productivity","Public Speaking"
        ].map((t) => (
          <div class="col-md-4 col-6">
            <span class="badge bg-primary w-100 text-start p-2">{t}</span>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- 🎯 OBJECTIVES -->
  <section class="py-5 bg-light">
    <div class="container">

      <h2 class="text-center mb-5">Program Outcomes</h2>

      <div class="row">
        {[
          "Clarity in goals",
          "Stronger leadership",
          "Better communication",
          "Higher confidence",
          "Improved productivity",
          "Emotional resilience"
        ].map((o) => (
          <div class="col-md-4 mb-3">
            <div class="p-3 border rounded bg-white text-center">
              ✔ {o}
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-dark text-white py-5 text-center">
    <div class="container">
      <h2 class="fw-bold mb-3">Ready to Transform?</h2>
      <p class="lead mb-4">
        Choose your path — personal mastery or team transformation.
      </p>
      <a href="/#contact" class="btn btn-warning btn-lg px-5">Get Started</a>
    </div>
  </section>

</BaseLayout>