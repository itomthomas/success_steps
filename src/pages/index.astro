---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <Fragment slot="head">
    <title>SuccessSteps | Premium Psychometric Counselling</title>
    <meta
      name="description"
      content="Premium psychometric assessment and private counselling for students and professionals seeking clarity, alignment, and growth."
    />
  </Fragment>

  <!-- HERO -->
  <section class="hero pt-5">
    <div class="container py-5 mt-5">
      <div class="row">
        <div class="col-lg-7">
          <h1 class="display-5 mb-3">
            Unlock Your True Potential Through Scientific Self-Discovery
          </h1>
          <p class="lead mb-4">
            A premium psychometric assessment and private counselling experience
            for students and professionals seeking clarity, alignment, and growth.
          </p>
          <a href="/assessment" class="btn btn-premium btn-lg me-3">
            Begin Psychometric Assessment
          </a>
          <a href="/register" class="btn btn-outline-light btn-lg">
            Register
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- PROBLEM -->
  <section class="py-5">
    <div class="container">
      <div class="text-center mb-5">
        <h2 class="section-title">
          Why Intelligent, Hardworking People Still Feel Stuck
        </h2>
      </div>
      <div class="row g-4">
        <div class="col-md-3"><div class="card card-premium p-4 h-100">Unclear career direction</div></div>
        <div class="col-md-3"><div class="card card-premium p-4 h-100">Pressure-driven decisions</div></div>
        <div class="col-md-3"><div class="card card-premium p-4 h-100">Burnout without fulfilment</div></div>
        <div class="col-md-3"><div class="card card-premium p-4 h-100">Untapped strengths</div></div>
      </div>
    </div>
  </section>

  <!-- ASSESSMENT -->
  <section id="assessment" class="py-5">
    <div class="container text-center">
      <h2 class="section-title mb-4">
        The SuccessSteps Psychometric Assessment
      </h2>
      <div class="card card-premium p-5">
        <p class="mb-4">
          A structured, in-depth assessment followed by private counselling
          and a personalised roadmap.
        </p>
        <a href="/register" class="btn btn-premium btn-lg">
          Request Access
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section id="contact" class="py-5 text-center">
    <div class="container">
      <h2 class="section-title mb-3">
        Clarity Is a Decision. Growth Is the Result.
      </h2>
      <a href="/register" class="btn btn-premium btn-lg me-3">
        Register
      </a>
      <a href="/contact" class="btn btn-outline-dark btn-lg">
        Contact Us
      </a>
    </div>
  </section>
</BaseLayout>
