---
// src/pages/index.astro
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>SuccessSteps | Premium Psychometric Counselling</title>
  <meta name="description" content="Premium psychometric assessment and private counselling for students and professionals seeking clarity, alignment, and growth." />

  <!-- Bootstrap CSS only -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

  <style>
    body {
      font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
      color: #1f2933;
    }
    .hero {
      background: radial-gradient(circle at top, #1e293b, #020617);
      color: #ffffff;
    }
    .hero h1 {
      font-weight: 600;
      letter-spacing: -0.02em;
    }
    .hero p {
      color: #cbd5e1;
      max-width: 640px;
    }
    .btn-premium {
      background-color: #0ea5a4;
      border: none;
      padding: 0.75rem 1.5rem;
      font-weight: 500;
    }
    .btn-premium:hover {
      background-color: #0d9488;
    }
    .section-muted {
      background-color: #f8fafc;
    }
    .section-title {
      font-weight: 600;
      letter-spacing: -0.01em;
    }
    .card-premium {
      border: none;
      border-radius: 1rem;
      box-shadow: 0 20px 40px rgba(15, 23, 42, 0.08);
    }
  </style>
</head>

<body>

  <!-- NAVBAR -->
  <nav class="navbar navbar-expand-lg bg-white border-bottom fixed-top">
    <div class="container">
      <a class="navbar-brand fw-semibold" href="/">SuccessSteps</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="nav">
        <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
          <li class="nav-item"><a class="nav-link" href="#approach">Our Approach</a></li>
          <li class="nav-item"><a class="nav-link" href="#assessment">Assessment</a></li>
          <li class="nav-item"><a class="nav-link" href="#counsellor">Counsellor</a></li>
          <li class="nav-item"><a class="nav-link" href="#contact">Contact</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero pt-5 mt-5">
    <div class="container py-5">
      <div class="row">
        <div class="col-lg-7">
          <h1 class="display-5 mb-3">Unlock Your True Potential Through Scientific Self‑Discovery</h1>
          <p class="lead mb-4">A premium psychometric assessment and private counselling experience for students and professionals seeking clarity, alignment, and meaningful growth.</p>
          <a href="/assessment" class="btn btn-premium btn-lg me-3">Begin Psychometric Assessment</a>
          <a href="#contact" class="btn btn-outline-light btn-lg">Speak to a Counsellor</a>
        </div>
      </div>
    </div>
  </section>

  <!-- PROBLEM -->
  <section class="py-5">
    <div class="container">
      <div class="text-center mb-5">
        <h2 class="section-title">Why Intelligent, Hardworking People Still Feel Stuck</h2>
      </div>
      <div class="row g-4">
        <div class="col-md-3"><div class="card card-premium p-4 h-100">Unclear career direction despite effort</div></div>
        <div class="col-md-3"><div class="card card-premium p-4 h-100">Decisions driven by pressure, not alignment</div></div>
        <div class="col-md-3"><div class="card card-premium p-4 h-100">Burnout without fulfilment</div></div>
        <div class="col-md-3"><div class="card card-premium p-4 h-100">Untapped strengths and potential</div></div>
      </div>
    </div>
  </section>

  <!-- APPROACH -->
  <section id="approach" class="section-muted py-5">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-6">
          <h2 class="section-title mb-3">Why Psychometric Insight Works</h2>
          <p>Our approach replaces guesswork with objective, science‑backed understanding of your personality, cognitive strengths, and behavioural patterns.</p>
          <ul>
            <li>Personality & behavioural mapping</li>
            <li>Cognitive & emotional intelligence profiling</li>
            <li>Decision‑making and work‑style insights</li>
          </ul>
        </div>
        <div class="col-lg-6">
          <div class="card card-premium p-4">Traits → Patterns → Strengths → Clarity</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ASSESSMENT -->
  <section id="assessment" class="py-5">
    <div class="container">
      <div class="text-center mb-4">
        <h2 class="section-title">The SuccessSteps Psychometric Assessment</h2>
      </div>
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="card card-premium p-5 text-center">
            <p class="mb-4">A structured, in‑depth assessment followed by a private counselling session and a personalised action roadmap.</p>
            <a href="/assessment" class="btn btn-premium btn-lg">Start Assessment</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- COUNSELLOR -->
  <section id="counsellor" class="section-muted py-5">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-4">
          <div class="card card-premium p-4">Professional Photograph</div>
        </div>
        <div class="col-lg-8">
          <h2 class="section-title">Your Counsellor</h2>
          <p>Led by an experienced practitioner integrating psychometrics, neuroscience, and ethical counselling to deliver clarity‑driven outcomes.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section id="contact" class="py-5">
    <div class="container text-center">
      <h2 class="section-title mb-3">Clarity Is a Decision. Growth Is the Result.</h2>
      <a href="/assessment" class="btn btn-premium btn-lg me-3">Begin Assessment</a>
      <a href="/contact" class="btn btn-outline-dark btn-lg">Contact Us</a>
    </div>
  </section>

  <footer class="border-top py-4 text-center small">
    © SuccessSteps. All rights reserved.
  </footer>

</body>
</html>
